<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CcDirectorSetup.Converters"
             x:Class="CcDirectorSetup.Steps.PrerequisitesStep">
    <UserControl.Resources>
        <converters:HexColorToBrushConverter x:Key="HexToBrush" />
    </UserControl.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Prerequisites"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="SubtitleText"
                       Text="Checking required software..."
                       Foreground="#CCCCCC"
                       FontSize="13"
                       Margin="0,8,0,16" />
        </StackPanel>

        <!-- Success banner (hidden by default) -->
        <Border x:Name="SuccessBanner"
                DockPanel.Dock="Bottom"
                Background="#1B3A2A"
                CornerRadius="6"
                Padding="16"
                Margin="0,16,0,0"
                IsVisible="False">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Width="32" Height="32" CornerRadius="16"
                        Background="#22C55E"
                        Margin="0,0,12,0">
                    <TextBlock Text="OK"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="All prerequisites met -- ready to install."
                           Foreground="#22C55E"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Button x:Name="RefreshButton" Content="Re-check"
                Classes="setup"
                DockPanel.Dock="Bottom"
                HorizontalAlignment="Left"
                Width="100"
                Margin="0,12,0,0"
                Click="RefreshButton_Click" />

        <ItemsControl x:Name="PrereqList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2A2D2E"
                            CornerRadius="4"
                            Padding="14,10"
                            Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <Border CornerRadius="3"
                                            Padding="6,1"
                                            Margin="8,0,0,0"
                                            Background="#3A1B1B"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Required"
                                                   Foreground="#CC4444"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="{Binding Description}"
                                           Foreground="#888888"
                                           FontSize="11"
                                           Margin="0,2,0,0" />

                                <TextBlock Text="{Binding Version}"
                                           Foreground="#AAAAAA"
                                           FontSize="11"
                                           Margin="0,2,0,0"
                                           IsVisible="{Binding Version, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                <!-- Install link (shown when prerequisite is not found) -->
                                <TextBlock Text="Download and install ->"
                                           Foreground="#007ACC"
                                           FontSize="11"
                                           Margin="0,4,0,0"
                                           Cursor="Hand"
                                           Tag="{Binding InstallUrl}"
                                           IsVisible="{Binding !IsFound}"
                                           PointerPressed="InstallLink_PointerPressed">
                                    <TextBlock.TextDecorations>
                                        <TextDecorationCollection>
                                            <TextDecoration Location="Underline" />
                                        </TextDecorationCollection>
                                    </TextBlock.TextDecorations>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
