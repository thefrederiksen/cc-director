{
  "name": "cc-browser",
  "version": "2.0.0",
  "type": "module",
  "description": "Browser automation for Claude Code via Chrome Extension + Native Messaging",
  "main": "src/daemon.mjs",
  "bin": {
    "cc-browser": "src/cli.mjs"
  },
  "scripts": {
    "start": "node src/daemon.mjs",
    "dev": "node --watch src/daemon.mjs",
    "test": "node --test test/**/*.test.mjs",
    "test:unit": "node --test test/unit/**/*.test.mjs",
    "test:integration": "node --test test/integration/**/*.test.mjs"
  },
  "dependencies": {
    "clipboardy": "^5.3.1",
    "keysender": "^2.4.0",
    "ws": "^8.14.2"
  }
}
