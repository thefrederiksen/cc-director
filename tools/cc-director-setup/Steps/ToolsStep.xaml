<UserControl x:Class="CcDirectorSetup.Steps.ToolsStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Header area (fixed) -->
        <StackPanel DockPanel.Dock="Top">
            <TextBlock x:Name="TitleText"
                       Text="Select Tool Groups"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold" />

            <TextBlock x:Name="DescriptionText"
                       Text="Choose which tool groups to install. You can change this later by running setup again."
                       Foreground="{StaticResource TextForeground}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       LineHeight="20" />

            <!-- Preset buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,10">
                <Button x:Name="StandardPreset" Content="Standard"
                        Width="90" Height="28" FontSize="12"
                        Click="StandardPreset_Click" />
                <Button x:Name="DeveloperPreset" Content="Developer"
                        Width="90" Height="28" FontSize="12"
                        Margin="8,0,0,0"
                        Click="DeveloperPreset_Click" />
                <Button x:Name="AllPreset" Content="All"
                        Width="60" Height="28" FontSize="12"
                        Margin="8,0,0,0"
                        Click="AllPreset_Click" />
            </StackPanel>
        </StackPanel>

        <!-- Footer (fixed) -->
        <TextBlock x:Name="ToolCountText"
                   DockPanel.Dock="Bottom"
                   Foreground="{StaticResource DimText}"
                   FontSize="12"
                   Margin="0,8,0,0" />

        <!-- Scrollable group list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,0">
            <StackPanel x:Name="GroupList" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
