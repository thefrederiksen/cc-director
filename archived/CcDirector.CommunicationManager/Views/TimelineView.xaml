<UserControl x:Class="CommunicationManager.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="DayGroups" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,16">
                        <!-- Day Header -->
                        <Border Padding="8,6" Margin="0,0,0,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#252526"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="Background" Value="#1B3A2A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#CCCCCC"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding DayLabel, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding DateDisplay}" Foreground="#888888" FontSize="12"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                                <Border Background="#404040" CornerRadius="8" Padding="6,1" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ItemCount}" Foreground="#CCCCCC" FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Time-slot items -->
                        <ItemsControl ItemsSource="{Binding Items}" Margin="16,0,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Time label -->
                                        <TextBlock Grid.Column="0" Text="{Binding TimeDisplay}"
                                                   Foreground="#888888" FontSize="11" FontFamily="Cascadia Mono, Consolas"
                                                   VerticalAlignment="Center"/>

                                        <!-- Timeline dot and line -->
                                        <Canvas Grid.Column="1" Width="16" Margin="0,0,8,0">
                                            <Ellipse Width="8" Height="8" Canvas.Left="4" Canvas.Top="6">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#007ACC"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Item.IsHold}" Value="True">
                                                                <Setter Property="Fill" Value="#D97706"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Item.IsAsap}" Value="True">
                                                                <Setter Property="Fill" Value="#22C55E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </Canvas>

                                        <!-- Item card -->
                                        <Border Grid.Column="2" Background="#2A2A2A" CornerRadius="4"
                                                Padding="10,6" Cursor="Hand"
                                                MouseLeftButtonDown="TimelineItem_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Platform badge -->
                                                <Border Grid.Column="0" Background="#333333" CornerRadius="3"
                                                        Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Item.PlatformIcon}" FontWeight="Bold"
                                                               FontSize="10" Foreground="#CCCCCC"/>
                                                </Border>

                                                <!-- Title -->
                                                <TextBlock Grid.Column="1" Text="{Binding Item.DisplayTitle}"
                                                           Foreground="#CCCCCC" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>

                                                <!-- Timing badge -->
                                                <Border Grid.Column="2" CornerRadius="3" Padding="6,2"
                                                        Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#094771"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Item.IsHold}" Value="True">
                                                                    <Setter Property="Background" Value="#3A2A1B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Item.IsAsap}" Value="True">
                                                                    <Setter Property="Background" Value="#1B3A2A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Item.ScheduleDisplayShort}" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#007ACC"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Item.IsHold}" Value="True">
                                                                        <Setter Property="Foreground" Value="#D97706"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Item.IsAsap}" Value="True">
                                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
