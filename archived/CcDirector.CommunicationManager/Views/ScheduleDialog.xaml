<Window x:Class="CommunicationManager.Views.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Send"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252526"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="TimingOptionStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Padding="12,10"
                                Background="#333333"
                                CornerRadius="4"
                                Cursor="Hand"
                                Margin="0,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#094771"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#007ACC"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3C3C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimePresetButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Padding="{TemplateBinding Padding}"
                                Background="#333333"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="When should this be sent?"
                   Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- Timing Options -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <RadioButton x:Name="AsapOption" Style="{StaticResource TimingOptionStyle}"
                         IsChecked="True" Checked="TimingOption_Checked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Send ASAP" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="  --  Dispatch immediately" Foreground="#888888" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="TomorrowMorningOption" Style="{StaticResource TimingOptionStyle}"
                         Checked="TimingOption_Checked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tomorrow morning" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TomorrowMorningLabel" Text="" Foreground="#888888" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="TomorrowAfternoonOption" Style="{StaticResource TimingOptionStyle}"
                         Checked="TimingOption_Checked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tomorrow afternoon" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TomorrowAfternoonLabel" Text="" Foreground="#888888" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="ScheduleOption" Style="{StaticResource TimingOptionStyle}"
                         Checked="TimingOption_Checked">
                <TextBlock Text="Schedule for..." Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
            </RadioButton>

            <RadioButton x:Name="HoldOption" Style="{StaticResource TimingOptionStyle}"
                         Checked="TimingOption_Checked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Hold" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="  --  Approve but don't auto-send" Foreground="#888888" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <!-- Custom Date/Time Picker (only visible when Schedule is selected) -->
        <Border x:Name="DateTimePanel" Grid.Row="2" Background="#1E1E1E" CornerRadius="4"
                Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Pick date and time" Foreground="#888888" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Date Picker -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Date:" Foreground="#AAAAAA" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="ScheduleDatePicker" Grid.Column="1"
                                Background="#333333" Foreground="#CCCCCC"
                                BorderBrush="#555555" BorderThickness="1"/>
                </Grid>

                <!-- Quick Time Presets -->
                <TextBlock Text="Quick times:" Foreground="#888888" FontSize="11" Margin="0,4,0,4"/>
                <WrapPanel Margin="0,0,0,8">
                    <Button Content="9:00 AM" Style="{StaticResource TimePresetButtonStyle}"
                            Click="TimePreset_Click" Tag="09:00"/>
                    <Button Content="10:00 AM" Style="{StaticResource TimePresetButtonStyle}"
                            Click="TimePreset_Click" Tag="10:00"/>
                    <Button Content="12:00 PM" Style="{StaticResource TimePresetButtonStyle}"
                            Click="TimePreset_Click" Tag="12:00"/>
                    <Button Content="2:00 PM" Style="{StaticResource TimePresetButtonStyle}"
                            Click="TimePreset_Click" Tag="14:00"/>
                    <Button Content="3:00 PM" Style="{StaticResource TimePresetButtonStyle}"
                            Click="TimePreset_Click" Tag="15:00"/>
                    <Button Content="5:00 PM" Style="{StaticResource TimePresetButtonStyle}"
                            Click="TimePreset_Click" Tag="17:00"/>
                    <Button Content="6:00 PM" Style="{StaticResource TimePresetButtonStyle}"
                            Click="TimePreset_Click" Tag="18:00"/>
                </WrapPanel>

                <!-- Custom Time Input -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Time:" Foreground="#AAAAAA" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="HourBox" Grid.Column="1" Text="9"
                             Background="#333333" Foreground="#CCCCCC" BorderBrush="#555555"
                             Padding="4,4" TextAlignment="Center" MaxLength="2"
                             TextChanged="TimeInput_Changed"/>
                    <TextBlock Grid.Column="2" Text=":" Foreground="#AAAAAA" FontSize="14"
                               VerticalAlignment="Center" Margin="4,0"/>
                    <TextBox x:Name="MinuteBox" Grid.Column="3" Text="00"
                             Background="#333333" Foreground="#CCCCCC" BorderBrush="#555555"
                             Padding="4,4" TextAlignment="Center" MaxLength="2"
                             TextChanged="TimeInput_Changed"/>
                    <ComboBox x:Name="AmPmBox" Grid.Column="5"
                              Background="#333333" Foreground="#CCCCCC" BorderBrush="#555555"
                              SelectedIndex="0" SelectionChanged="TimeInput_Changed">
                        <ComboBoxItem Content="AM"/>
                        <ComboBoxItem Content="PM"/>
                    </ComboBox>
                </Grid>

                <!-- Schedule summary -->
                <TextBlock x:Name="ScheduleSummary" Text="" Foreground="#007ACC" FontSize="12"
                           FontWeight="SemiBold" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True" Click="Cancel_Click"/>
            <Button x:Name="ConfirmButton" Content="Approve" Width="100" Height="28"
                    Background="#28A745" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True" Click="Confirm_Click"
                    Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
