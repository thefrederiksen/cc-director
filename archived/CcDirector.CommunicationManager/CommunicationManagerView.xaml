<UserControl x:Class="CommunicationManager.CommunicationManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommunicationManager.ViewModels"
             xmlns:conv="clr-namespace:CommunicationManager.Converters"
             xmlns:views="clr-namespace:CommunicationManager.Views"
             mc:Ignorable="d"
             Background="#1E1E1E">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/PlatformPreviews.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:NullToVisibilityConverter x:Key="NullToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

            <!-- Platform Template Selector -->
            <views:PlatformTemplateSelector x:Key="PlatformSelector"
                LinkedInTemplate="{StaticResource LinkedInPreviewTemplate}"
                TwitterTemplate="{StaticResource TwitterPreviewTemplate}"
                RedditTemplate="{StaticResource RedditPreviewTemplate}"
                EmailTemplate="{StaticResource EmailPreviewTemplate}"
                ArticleTemplate="{StaticResource ArticlePreviewTemplate}"
                FacebookTemplate="{StaticResource FacebookPreviewTemplate}"
                WhatsAppTemplate="{StaticResource WhatsAppPreviewTemplate}"
                YouTubeTemplate="{StaticResource YouTubePreviewTemplate}"
                DefaultTemplate="{StaticResource DefaultPreviewTemplate}"/>

            <Style x:Key="TabButtonStyle" TargetType="RadioButton">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border"
                                    Padding="16,8"
                                    Background="Transparent"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="Transparent"
                                    Cursor="Hand">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#007ACC"/>
                                    <Setter TargetName="border" Property="Background" Value="#094771"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterChipStyle" TargetType="Button">
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="#333333"/>
                <Setter Property="Foreground" Value="#AAAAAA"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#444444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterChipActiveStyle" TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                <Setter Property="Background" Value="#094771"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ApproveButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Background" Value="#28A745"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#28A745"/>
            </Style>

            <Style x:Key="RejectButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Background" Value="#DC3545"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#DC3545"/>
            </Style>

            <Style x:Key="LinkButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Background" Value="#007ACC"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#007ACC"/>
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Background" Value="#333333"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="BorderBrush" Value="#555555"/>
            </Style>

            <Style x:Key="ListItemStyle" TargetType="ListBoxItem">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="#3C3C3C"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tabs -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <RadioButton x:Name="PendingTab"
                                 Style="{StaticResource TabButtonStyle}"
                                 IsChecked="True"
                                 Checked="PendingTab_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Pending" Foreground="#CCCCCC"/>
                            <Border Background="#007ACC" CornerRadius="10" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding PendingCount, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="{Binding PendingCount}" Foreground="White" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="ApprovedTab"
                                 Style="{StaticResource TabButtonStyle}"
                                 Checked="ApprovedTab_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Approved" Foreground="#CCCCCC"/>
                            <Border Background="#28A745" CornerRadius="10" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding ApprovedCount, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="{Binding ApprovedCount}" Foreground="White" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="RejectedTab"
                                 Style="{StaticResource TabButtonStyle}"
                                 Checked="RejectedTab_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Rejected" Foreground="#CCCCCC"/>
                            <Border Background="#DC3545" CornerRadius="10" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding RejectedCount, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="{Binding RejectedCount}" Foreground="White" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SentTab"
                                 Style="{StaticResource TabButtonStyle}"
                                 Checked="SentTab_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sent" Foreground="#CCCCCC"/>
                            <Border Background="#17A2B8" CornerRadius="10" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding SentCount, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="{Binding SentCount}" Foreground="White" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="ErrorTab"
                                 Style="{StaticResource TabButtonStyle}"
                                 Checked="ErrorTab_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Error" Foreground="#CCCCCC"/>
                            <Border Background="#E8A317" CornerRadius="10" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding ErrorCount, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="{Binding ErrorCount}" Foreground="White" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="SEND ALL" Command="{Binding SendAllCommand}"
                            IsEnabled="{Binding HasApprovedItems}"
                            Padding="20,10" Margin="4" FontSize="15" FontWeight="Bold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Padding="{TemplateBinding Padding}"
                                        Background="#DC3545" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#C82333"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#6C1A23"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="White"/>
                        </Button.Foreground>
                    </Button>
                    <Button Content="Refresh" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Platform Filter Bar -->
        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="12,4">
            <StackPanel>
                <StackPanel x:Name="FilterBar" Orientation="Horizontal">
                    <Button Content="All" Click="FilterChip_Click" Tag="All"
                            Style="{StaticResource FilterChipActiveStyle}"/>
                    <Button Content="Email" Click="FilterChip_Click" Tag="email"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="LinkedIn" Click="FilterChip_Click" Tag="linkedin"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="Facebook" Click="FilterChip_Click" Tag="facebook"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="YouTube" Click="FilterChip_Click" Tag="youtube"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="WhatsApp" Click="FilterChip_Click" Tag="whatsapp"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="Reddit" Click="FilterChip_Click" Tag="reddit"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="Twitter" Click="FilterChip_Click" Tag="twitter"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="Blog" Click="FilterChip_Click" Tag="blog"
                            Style="{StaticResource FilterChipStyle}"/>
                </StackPanel>

                <!-- Date Filter Bar (Approved tab only) -->
                <StackPanel x:Name="DateFilterBar" Orientation="Horizontal" Margin="0,4,0,0"
                            Visibility="{Binding ElementName=ApprovedTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Schedule:" Foreground="#888888" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="Today" Click="DateFilterChip_Click" Tag="Today"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="Tomorrow" Click="DateFilterChip_Click" Tag="Tomorrow"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="This Week" Click="DateFilterChip_Click" Tag="This Week"
                            Style="{StaticResource FilterChipStyle}"/>
                    <Button Content="All Upcoming" Click="DateFilterChip_Click" Tag="All Upcoming"
                            Style="{StaticResource FilterChipActiveStyle}"/>

                    <!-- View Toggle (List / Timeline) -->
                    <Border Margin="16,0,0,0" Background="#252526" CornerRadius="4" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ListViewBtn" Content="List" Click="ViewToggle_Click" Tag="List"
                                    Style="{StaticResource FilterChipActiveStyle}"/>
                            <Button x:Name="TimelineViewBtn" Content="Timeline" Click="ViewToggle_Click" Tag="Timeline"
                                    Style="{StaticResource FilterChipStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - List / Timeline -->
            <Border Grid.Column="0" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Background="#1E1E1E">
                <Grid>
                    <!-- Timeline View (shown on Approved tab when Timeline is selected) -->
                    <views:TimelineView x:Name="ApprovedTimeline"
                                        Items="{Binding FilteredItems}"
                                        Visibility="Collapsed"
                                        ItemSelected="Timeline_ItemSelected"/>

                    <!-- List View -->
                    <ListBox x:Name="ItemList"
                         ItemsSource="{Binding FilteredItems}"
                         SelectedItem="{Binding SelectedItem}"
                         ItemContainerStyle="{StaticResource ListItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#CCCCCC"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Platform/Type Badge -->
                                <Border Grid.Column="0" Grid.RowSpan="2"
                                        Background="#333333" CornerRadius="4"
                                        Padding="8,4" Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PlatformIcon}" FontWeight="Bold" FontSize="12"
                                                   HorizontalAlignment="Center" Foreground="#CCCCCC"/>
                                        <TextBlock Text="{Binding TypeIcon}" FontSize="9" Foreground="#888888"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Title -->
                                <StackPanel Grid.Column="1" Grid.Row="0">
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               FontWeight="SemiBold" Foreground="#CCCCCC"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding RecipientDisplay}"
                                               Foreground="#D97706" FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding HasRecipient, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- Meta info -->
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TicketDisplay}" Foreground="#007ACC" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text=" - " Foreground="#666666" FontSize="11"/>
                                        <TextBlock Text="{Binding PersonaDisplay}" Foreground="#888888" FontSize="11"/>
                                        <TextBlock Text=" - " Foreground="#666666" FontSize="11"/>
                                        <TextBlock Text="{Binding CreatedBy}" Foreground="#666666" FontSize="11"/>
                                    </StackPanel>
                                    <!-- Schedule info (visible for approved items) -->
                                    <TextBlock Text="{Binding ScheduleDisplayShort}" FontSize="10" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#007ACC"/>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="approved">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsHold}" Value="True">
                                                        <Setter Property="Foreground" Value="#D97706"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsAsap}" Value="True">
                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Right Panel - Details -->
            <Grid Grid.Column="2" Visibility="{Binding SelectedItem, Converter={StaticResource NullToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header Info -->
                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Background="#007ACC" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SelectedItem.Platform}" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#6C757D" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SelectedItem.Type}" Foreground="White"/>
                                </Border>
                                <Border Background="#D97706" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="{Binding SelectedItem.PersonaDisplay}" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedItem.DisplayTitle}" FontSize="18" FontWeight="Bold"
                                       Foreground="#CCCCCC" Margin="0,0,0,4" TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Created by " Foreground="#888888"/>
                                <TextBlock Text="{Binding SelectedItem.CreatedBy}" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                                <TextBlock Text=" at " Foreground="#888888"/>
                                <TextBlock Text="{Binding SelectedItem.CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="#888888"/>
                            </StackPanel>

                            <!-- Recipient Info -->
                            <Border Background="#2A2A1B" CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                    Visibility="{Binding SelectedItem.HasRecipient, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="To: " Foreground="#888888" FontSize="12"/>
                                        <TextBlock Text="{Binding SelectedItem.RecipientDisplay}" FontWeight="SemiBold"
                                                   Foreground="#D97706" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               Visibility="{Binding SelectedItem.HasRecipientProfile, Converter={StaticResource BoolToVis}}">
                                        <Hyperlink NavigateUri="{Binding SelectedItem.Recipient.ProfileUrl}"
                                                   RequestNavigate="Hyperlink_RequestNavigate"
                                                   Foreground="#007ACC" FontSize="11">
                                            <Run Text="{Binding SelectedItem.Recipient.ProfileUrl, Mode=OneWay}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Schedule Info (for Approved tab) -->
                            <Border CornerRadius="4" Padding="8,4" Margin="0,0,0,8"
                                    Visibility="{Binding ElementName=ApprovedTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1B2A3A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.IsHold}" Value="True">
                                                <Setter Property="Background" Value="#3A2A1B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedItem.IsAsap}" Value="True">
                                                <Setter Property="Background" Value="#1B3A2A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SelectedItem.SendTimingDisplay}" FontWeight="SemiBold" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#007ACC"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.IsHold}" Value="True">
                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedItem.IsAsap}" Value="True">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Posted At (for Sent tab) -->
                            <TextBlock Text="{Binding SelectedItem.PostedAtDisplay}"
                                       Foreground="#28A745" FontWeight="SemiBold" FontSize="13"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding SelectedItem.PostedAt, Converter={StaticResource NullToVis}}"/>

                            <!-- Rejected At (for Rejected tab) -->
                            <TextBlock Text="{Binding SelectedItem.RejectedAtDisplay}"
                                       Foreground="#DC3545" FontWeight="SemiBold" FontSize="13"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding ElementName=RejectedTab, Path=IsChecked, Converter={StaticResource BoolToVis}}"/>

                            <!-- Error At (for Error tab) -->
                            <TextBlock Text="{Binding SelectedItem.ErrorAtDisplay}"
                                       Foreground="#E8A317" FontWeight="SemiBold" FontSize="13"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding ElementName=ErrorTab, Path=IsChecked, Converter={StaticResource BoolToVis}}"/>

                            <!-- Rejection Reason (for Rejected tab) -->
                            <Border Background="#3C1515" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                                    Visibility="{Binding ElementName=RejectedTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                                <StackPanel Visibility="{Binding SelectedItem.RejectionReason, Converter={StaticResource NullToVis}}">
                                    <TextBlock Text="Rejection Reason:" FontWeight="SemiBold" Foreground="#DC3545" FontSize="11"/>
                                    <TextBlock Text="{Binding SelectedItem.RejectionReason}" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Error Reason (for Error tab) -->
                            <Border Background="#3C2A0A" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                                    Visibility="{Binding ElementName=ErrorTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                                <StackPanel Visibility="{Binding SelectedItem.RejectionReason, Converter={StaticResource NullToVis}}">
                                    <TextBlock Text="Error Reason:" FontWeight="SemiBold" Foreground="#E8A317" FontSize="11"/>
                                    <TextBlock Text="{Binding SelectedItem.RejectionReason}" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Media Attachments -->
                            <Border Background="#1A2A3A" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                                    Visibility="{Binding SelectedItem.HasMedia, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedItem.MediaCountDisplay}" FontWeight="SemiBold" Foreground="#007ACC" FontSize="11" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding SelectedItem.Media}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="[*] " Foreground="#007ACC"/>
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#CCCCCC"/>
                                                    <TextBlock Text=" (" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding FileSizeDisplay}" Foreground="#888888"/>
                                                    <TextBlock Text=")" Foreground="#888888"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Links -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="Open Context" Style="{StaticResource LinkButtonStyle}"
                                    Command="{Binding OpenContextUrlCommand}"
                                    Visibility="{Binding SelectedItem.ContextUrl, Converter={StaticResource NullToVis}}"/>
                            <Button Content="Open Destination" Style="{StaticResource LinkButtonStyle}"
                                    Command="{Binding OpenDestinationUrlCommand}"
                                    Visibility="{Binding SelectedItem.DestinationUrl, Converter={StaticResource NullToVis}}"/>
                            <Button Content="Copy Destination" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding CopyDestinationUrlCommand}"
                                    Visibility="{Binding SelectedItem.DestinationUrl, Converter={StaticResource NullToVis}}"/>
                        </StackPanel>

                        <!-- Reason -->
                        <Border Grid.Row="2" Background="#1A2D1A" CornerRadius="4" Padding="12" Margin="0,0,0,8"
                                Visibility="{Binding SelectedItem.Reason, Converter={StaticResource NullToVis}}">
                            <StackPanel>
                                <TextBlock Text="REASON" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedItem.Reason}" Foreground="#AACCAA" TextWrapping="Wrap" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Context Info -->
                        <Border Grid.Row="3" Background="#2D2A1A" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                                Visibility="{Binding SelectedItem.ContextTitle, Converter={StaticResource NullToVis}}">
                            <StackPanel>
                                <TextBlock Text="RESPONDING TO" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedItem.ContextTitle}" FontWeight="SemiBold" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedItem.ContextAuthor}" Foreground="#888888" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Content Area -->
                        <StackPanel Grid.Row="4" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                            <!-- Preview Toggle -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="View:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#888888"/>
                                <Border CornerRadius="4" Padding="12,6" Margin="0,0,4,0" Cursor="Hand"
                                        MouseDown="PreviewToggle_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#333333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                                    <Setter Property="Background" Value="#094771"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Preview">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                                        <Setter Property="Foreground" Value="#007ACC"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <Border CornerRadius="4" Padding="12,6" Cursor="Hand"
                                        MouseDown="RawToggle_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#333333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPreviewMode}" Value="False">
                                                    <Setter Property="Background" Value="#094771"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Raw">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPreviewMode}" Value="False">
                                                        <Setter Property="Foreground" Value="#007ACC"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <!-- Preview Mode Content (platform previews stay light for fidelity) -->
                            <ContentControl Content="{Binding SelectedItem}"
                                            ContentTemplateSelector="{StaticResource PlatformSelector}"
                                            Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVis}}"
                                            Margin="0,0,0,16"/>

                            <!-- Raw Mode Content -->
                            <Border Background="#252526" CornerRadius="4" Padding="16" Margin="0,0,0,16"
                                    Visibility="{Binding IsPreviewMode, Converter={StaticResource InverseBoolToVis}}">
                                <TextBox Text="{Binding SelectedItem.Content, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#CCCCCC"
                                         FontSize="14"
                                         FontFamily="Segoe UI"
                                         AcceptsReturn="True"/>
                            </Border>
                        </StackPanel>

                        <!-- Edit Mode -->
                        <Border Grid.Row="4" Background="#2D2A1A" CornerRadius="4" Padding="16" Margin="0,0,0,16"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0"
                                         Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         BorderThickness="1"
                                         BorderBrush="#555555"
                                         Background="#1E1E1E"
                                         Foreground="#CCCCCC"
                                         CaretBrush="#CCCCCC"
                                         Padding="8"
                                         FontSize="14"
                                         FontFamily="Segoe UI"
                                         MinHeight="200"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelEditCommand}"/>
                                    <Button Content="Save" Style="{StaticResource ApproveButtonStyle}" Command="{Binding SaveEditCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <!-- Action Buttons - Fixed at bottom -->
                <Border Grid.Row="1" Background="#252526" CornerRadius="4" Padding="16" Margin="20,0,20,12"
                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel>
                        <!-- Pending Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding ElementName=PendingTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                            <Button Content="Approve &amp; Send" Style="{StaticResource ApproveButtonStyle}"
                                    Click="ApproveAndSend_Click" Width="140"/>
                            <Button Content="Approve &amp; Schedule" Style="{StaticResource LinkButtonStyle}"
                                    Click="ApproveAndSchedule_Click" Width="160"/>
                            <Button Content="Edit" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding StartEditCommand}" Width="80"/>
                            <Button Content="Skip" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SkipCommand}" Width="80"/>
                            <Button Content="Reject" Style="{StaticResource RejectButtonStyle}"
                                    Command="{Binding RejectCommand}" Width="100"/>
                            <Button Content="Delete" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteCommand}" Width="80" Foreground="#DC3545"/>
                        </StackPanel>

                        <!-- Approved Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding ElementName=ApprovedTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                            <Button Content="Post to LinkedIn" Style="{StaticResource ApproveButtonStyle}"
                                    Command="{Binding PostToLinkedInCommand}" Width="140"
                                    Visibility="{Binding SelectedItem.IsLinkedIn, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="Reschedule" Style="{StaticResource LinkButtonStyle}"
                                    Click="Reschedule_Click" Width="100"/>
                            <Button Content="Move to Review" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding MoveToReviewCommand}" Width="120"/>
                            <Button Content="Delete" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteCommand}" Width="80" Foreground="#DC3545"/>
                        </StackPanel>

                        <!-- Rejected Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding ElementName=RejectedTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                            <Button Content="Move to Review" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding MoveToReviewCommand}" Width="120"/>
                            <Button Content="Delete" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteCommand}" Width="80" Foreground="#DC3545"/>
                        </StackPanel>

                        <!-- Sent Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding ElementName=SentTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                            <Button Content="Delete" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteCommand}" Width="80" Foreground="#DC3545"/>
                        </StackPanel>

                        <!-- Error Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding ElementName=ErrorTab, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                            <Button Content="Retry" Style="{StaticResource ApproveButtonStyle}"
                                    Command="{Binding RetryErrorCommand}" Width="100"/>
                            <Button Content="Delete" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteCommand}" Width="80" Foreground="#DC3545"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Empty State -->
            <TextBlock Grid.Column="2"
                       Text="Select an item to review"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#666666"
                       FontSize="16"
                       Visibility="{Binding SelectedItem, Converter={StaticResource NullToVis}, ConverterParameter=Inverse}"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#888888" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
