<Window x:Class="CcDirector.Wpf.McpServersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCP Server Management"
        Width="800" Height="550"
        MinWidth="650" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="MCP Server Management"
                   Foreground="#CCCCCC"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Top bar: scope + import -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="Scope:"
                           Foreground="#888888" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="ScopeCombo"
                          Width="300" Height="26"
                          Background="#1E1E1E" Foreground="#CCCCCC"
                          BorderBrush="#3C3C3C"
                          SelectionChanged="ScopeCombo_SelectionChanged" />
            </StackPanel>

            <Button Grid.Column="2"
                    Content="Import from Claude Desktop"
                    Height="26" Padding="12,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnImportDesktop_Click" />
        </Grid>

        <!-- Main content: left list + right edit form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: server list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox x:Name="ServerList"
                         Grid.Row="0"
                         Background="#1E1E1E"
                         Foreground="#CCCCCC"
                         BorderBrush="#3C3C3C"
                         BorderThickness="1"
                         FontSize="12"
                         SelectionChanged="ServerList_SelectionChanged" />

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Add"
                            Width="60" Height="26"
                            Background="#007ACC" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnAdd_Click" />
                    <Button Content="Remove"
                            Width="70" Height="26"
                            Background="#3C3C3C" Foreground="#CCCCCC"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnRemove_Click" Margin="6,0,0,0" />
                </StackPanel>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          Focusable="False"
                          Background="#252526"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" />

            <!-- Right panel: edit form -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="12,0,0,0">
                <StackPanel x:Name="EditPanel">

                    <!-- Name -->
                    <TextBlock Text="Name" Foreground="#CCCCCC" FontSize="13"
                               FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Unique identifier for this MCP server"
                               Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                    <TextBox x:Name="NameInput"
                             Width="300" HorizontalAlignment="Left"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                             Padding="8,6" FontSize="12"
                             FontFamily="Cascadia Mono, Consolas" />

                    <!-- Transport Type -->
                    <TextBlock Text="Transport Type" Foreground="#CCCCCC" FontSize="13"
                               FontWeight="SemiBold" Margin="0,16,0,4" />
                    <TextBlock Text="stdio = local process, sse = remote HTTP endpoint"
                               Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                    <ComboBox x:Name="TransportCombo"
                              Width="160" HorizontalAlignment="Left"
                              Background="#1E1E1E" Foreground="#CCCCCC"
                              BorderBrush="#3C3C3C"
                              SelectionChanged="TransportCombo_SelectionChanged" />

                    <!-- Command (stdio) -->
                    <StackPanel x:Name="StdioPanel">
                        <TextBlock Text="Command" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,16,0,4" />
                        <TextBlock Text="Executable to run (e.g. npx, node, python)"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                        <TextBox x:Name="CommandInput"
                                 Width="400" HorizontalAlignment="Left"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                                 Padding="8,6" FontSize="12"
                                 FontFamily="Cascadia Mono, Consolas" />
                    </StackPanel>

                    <!-- URL (sse) -->
                    <StackPanel x:Name="SsePanel" Visibility="Collapsed">
                        <TextBlock Text="URL" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,16,0,4" />
                        <TextBlock Text="SSE endpoint URL (e.g. http://localhost:3000/sse)"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                        <TextBox x:Name="UrlInput"
                                 Width="400" HorizontalAlignment="Left"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                                 Padding="8,6" FontSize="12"
                                 FontFamily="Cascadia Mono, Consolas" />
                    </StackPanel>

                    <!-- Args -->
                    <TextBlock Text="Arguments" Foreground="#CCCCCC" FontSize="13"
                               FontWeight="SemiBold" Margin="0,16,0,4" />
                    <TextBlock Text="One argument per line"
                               Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                    <TextBox x:Name="ArgsInput"
                             Width="400" HorizontalAlignment="Left"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinLines="3" MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                             Padding="8,6" FontSize="12"
                             FontFamily="Cascadia Mono, Consolas" />

                    <!-- Environment Variables -->
                    <TextBlock Text="Environment Variables" Foreground="#CCCCCC" FontSize="13"
                               FontWeight="SemiBold" Margin="0,16,0,4" />
                    <TextBlock Text="One per line: KEY=VALUE"
                               Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                    <TextBox x:Name="EnvInput"
                             Width="400" HorizontalAlignment="Left"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinLines="3" MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                             Padding="8,6" FontSize="12"
                             FontFamily="Cascadia Mono, Consolas" />

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" Foreground="#22C55E" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button Content="Save" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnSave_Click" Margin="0,0,8,0" />
            <Button Content="Close" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
