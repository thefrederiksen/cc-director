<Window x:Class="CcDirector.Wpf.StatsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Code Usage Statistics"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Usage Statistics"
                   Foreground="#CCCCCC"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <!-- Loading indicator -->
        <TextBlock x:Name="LoadingText" Grid.Row="1"
                   Text="Loading..."
                   Foreground="#888888"
                   FontSize="12"
                   FontStyle="Italic"
                   Margin="0,0,0,8" />

        <!-- Stats grid -->
        <DataGrid x:Name="StatsGrid" Grid.Row="2"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  Background="#1E1E1E"
                  Foreground="#CCCCCC"
                  BorderBrush="#3C3C3C"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#3C3C3C"
                  RowBackground="#1E1E1E"
                  AlternatingRowBackground="#252526"
                  HeadersVisibility="Column"
                  FontFamily="Cascadia Mono, Consolas"
                  FontSize="11"
                  Visibility="Collapsed">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2D2D2D" />
                    <Setter Property="Foreground" Value="#CCCCCC" />
                    <Setter Property="Padding" Value="8,6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontSize" Value="11" />
                    <Setter Property="BorderBrush" Value="#3C3C3C" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,4" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Foreground" Value="#CCCCCC" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#094771" />
                            <Setter Property="Foreground" Value="#CCCCCC" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2D2E" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- No data message -->
        <TextBlock x:Name="NoDataText" Grid.Row="2"
                   Text="No statistics data found"
                   Foreground="#666666"
                   FontSize="12"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed" />

        <!-- Close button -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
