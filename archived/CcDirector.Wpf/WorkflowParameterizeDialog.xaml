<Window x:Class="CcDirector.Wpf.WorkflowParameterizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parameterize Workflow"
        Width="700" Height="500"
        Background="#252526"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Foreground="#CCCCCC" FontSize="13" TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Text="Click a value to replace it with a {variable} placeholder. Values already parameterized are shown in blue." />

        <!-- Step values list -->
        <Border Grid.Row="1" BorderBrush="#3C3C3C" BorderThickness="1"
                Background="#1E1E1E" Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="StepsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                                    Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding StepIndex}"
                                               Foreground="#666666" FontSize="10"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Command}"
                                               Foreground="#CCCCCC" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding ParamKey}"
                                               Foreground="#888888" FontSize="11"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding DisplayValue}"
                                               Foreground="{Binding ValueColor}" FontSize="11"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding RawValue}" />
                                    <Button Grid.Column="4" Content="Set Var"
                                            MinWidth="60" Height="24" FontSize="10"
                                            Background="#3C3C3C" Foreground="#CCCCCC"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="4,0,0,0"
                                            Click="BtnSetVar_Click"
                                            Tag="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Current parameters summary -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="DEFINED PARAMETERS" Foreground="#888888"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock x:Name="ParamsSummary" Foreground="#CCCCCC" FontSize="11"
                       Text="None" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Save" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True" Click="BtnSave_Click" />
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
