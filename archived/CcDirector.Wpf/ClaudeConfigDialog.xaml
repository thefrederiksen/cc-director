<Window x:Class="CcDirector.Wpf.ClaudeConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Code Settings"
        Width="750" Height="680"
        MinWidth="550" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Claude Code Settings"
                   Foreground="#CCCCCC"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Tab Control -->
        <TabControl x:Name="ConfigTabs" Grid.Row="1"
                    Background="#1E1E1E" BorderThickness="0">

            <!-- ═══ General Tab ═══ -->
            <TabItem Header="General" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <!-- Permission Mode -->
                        <TextBlock Text="Permission Mode" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="How Claude asks before taking actions"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                        <ComboBox x:Name="PermissionModeCombo"
                                  Width="220" HorizontalAlignment="Left"
                                  Background="#1E1E1E" Foreground="#CCCCCC"
                                  BorderBrush="#3C3C3C" />

                        <!-- Model Override -->
                        <TextBlock Text="Model Override" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,16,0,4" />
                        <TextBlock Text="Leave blank for default. e.g. claude-sonnet-4-6, claude-haiku-4-5"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                        <TextBox x:Name="ModelOverrideInput"
                                 Width="300" HorizontalAlignment="Left"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                                 Padding="8,6" FontSize="12"
                                 FontFamily="Cascadia Mono, Consolas" />

                        <!-- Effort Level -->
                        <TextBlock Text="Effort Level" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,16,0,4" />
                        <TextBlock Text="low = fast/cheap, high = thorough"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                        <ComboBox x:Name="EffortLevelCombo"
                                  Width="220" HorizontalAlignment="Left"
                                  Background="#1E1E1E" Foreground="#CCCCCC"
                                  BorderBrush="#3C3C3C" />

                        <!-- Max Output Tokens -->
                        <TextBlock Text="Max Output Tokens" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,16,0,4" />
                        <TextBlock Text="Max tokens per response (up to 64000, default 32000)"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                        <TextBox x:Name="MaxTokensInput"
                                 Width="140" HorizontalAlignment="Left"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                                 Padding="8,6" FontSize="12"
                                 FontFamily="Cascadia Mono, Consolas" />

                        <!-- Bash Timeout -->
                        <TextBlock Text="Bash Timeout (ms)" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,16,0,4" />
                        <TextBlock Text="Default timeout for bash commands (default 120000)"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,6" />
                        <TextBox x:Name="BashTimeoutInput"
                                 Width="140" HorizontalAlignment="Left"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                                 Padding="8,6" FontSize="12"
                                 FontFamily="Cascadia Mono, Consolas" />

                        <!-- Auto-Updates -->
                        <CheckBox x:Name="AutoUpdatesCheck"
                                  Content="Auto-Updates"
                                  Foreground="#CCCCCC" FontSize="13"
                                  Margin="0,16,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Permissions Tab ═══ -->
            <TabItem Header="Permissions" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <!-- Allowed Tools -->
                        <TextBlock Text="Allowed Tools" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ListBox x:Name="AllowedToolsList"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3C3C3C" BorderThickness="1"
                                 MinHeight="60" MaxHeight="160"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBox x:Name="AddAllowInput"
                                     Width="260"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                                     Padding="6,4" FontSize="11"
                                     FontFamily="Cascadia Mono, Consolas"
                                     KeyDown="AddAllowInput_KeyDown" />
                            <Button Content="Add" Width="50" Height="26"
                                    Background="#007ACC" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnAddAllow_Click" Margin="6,0,0,0" />
                            <Button Content="Remove" Width="60" Height="26"
                                    Background="#3C3C3C" Foreground="#CCCCCC"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnRemoveAllow_Click" Margin="6,0,0,0" />
                        </StackPanel>

                        <!-- Denied Tools -->
                        <TextBlock Text="Denied Tools" Foreground="#CCCCCC" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,20,0,8" />
                        <ListBox x:Name="DeniedToolsList"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3C3C3C" BorderThickness="1"
                                 MinHeight="60" MaxHeight="160"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBox x:Name="AddDenyInput"
                                     Width="260"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                                     Padding="6,4" FontSize="11"
                                     FontFamily="Cascadia Mono, Consolas"
                                     KeyDown="AddDenyInput_KeyDown" />
                            <Button Content="Add" Width="50" Height="26"
                                    Background="#007ACC" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnAddDeny_Click" Margin="6,0,0,0" />
                            <Button Content="Remove" Width="60" Height="26"
                                    Background="#3C3C3C" Foreground="#CCCCCC"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnRemoveDeny_Click" Margin="6,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Plugins Tab ═══ -->
            <TabItem Header="Plugins" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <TextBlock Text="Toggle plugins on or off. Changes are saved to settings.json."
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,12" />
                        <ItemsControl x:Name="PluginsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  Foreground="#CCCCCC" FontSize="13">
                                            <CheckBox.Content>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="#CCCCCC" />
                                            </CheckBox.Content>
                                        </CheckBox>
                                        <TextBlock Text="{Binding FullKey}" Foreground="#666666"
                                                   FontSize="10" Margin="20,2,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoPluginsText" Text="No plugins configured"
                                   Foreground="#666666" FontSize="12" FontStyle="Italic"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Hooks Tab ═══ -->
            <TabItem Header="Hooks" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <TextBlock Text="Read-only view. Use the Files tab to open settings.json for editing."
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,12" />
                        <TextBlock x:Name="NoHooksText" Text="No hooks configured"
                                   Foreground="#666666" FontSize="12" FontStyle="Italic"
                                   Visibility="Collapsed" />
                        <ItemsControl x:Name="HooksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="{Binding EventName}" Foreground="#007ACC"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4" />
                                        <ItemsControl ItemsSource="{Binding Commands}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#AAAAAA"
                                                               FontSize="11"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               TextWrapping="Wrap" Margin="12,1,0,1" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Files Tab ═══ -->
            <TabItem Header="Files" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <TextBlock Text="Click Open to edit a file in your default editor."
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,12" />
                        <ItemsControl x:Name="FilesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" Foreground="#CCCCCC"
                                                       FontSize="12" FontWeight="Medium" />
                                            <TextBlock Text="{Binding FilePath}" Foreground="#666666"
                                                       FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Button Content="Open" Width="60" Height="24"
                                                    Background="#3C3C3C" Foreground="#CCCCCC"
                                                    BorderThickness="0" Cursor="Hand"
                                                    IsEnabled="{Binding Exists}"
                                                    Click="BtnOpenFile_Click"
                                                    Tag="{Binding FilePath}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="SaveStatusText" Foreground="#22C55E" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button Content="Reload" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnReload_Click" Margin="0,0,8,0" />
            <Button Content="Save" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnSave_Click" Margin="0,0,8,0" />
            <Button Content="Close" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
