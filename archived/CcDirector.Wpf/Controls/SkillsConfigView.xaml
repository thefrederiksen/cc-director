<UserControl x:Class="CcDirector.Wpf.Controls.SkillsConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PanelBackground}">

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}" />
    </UserControl.InputBindings>
    <UserControl.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"
                        Executed="SaveCommand_Executed" CanExecute="SaveCommand_CanExecute" />
    </UserControl.CommandBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Scope badge style -->
        <Style x:Key="ScopeBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>

        <!-- Tree section header style -->
        <Style x:Key="SectionHeader" TargetType="ToggleButton">
            <Setter Property="IsChecked" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Padding="8,6" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2D2E" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <Path x:Name="Arrow" DockPanel.Dock="Left"
                                      Data="M 0,0 L 5,4 L 0,8 Z"
                                      Fill="#AAAAAA" Margin="0,0,8,0"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="90" />
                                    </Path.RenderTransform>
                                </Path>
                                <ContentPresenter VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tree item (selectable row) -->
        <Style x:Key="TreeItem" TargetType="Border">
            <Setter Property="Padding" Value="12,5,8,5" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toolbar button -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Height" Value="26" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger button (delete/remove) -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Foreground" Value="#F87171" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A2020" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="240" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Tree browser -->
        <DockPanel Grid.Column="0" Background="#252526">

            <!-- Header -->
            <DockPanel DockPanel.Dock="Top" Margin="16,14,16,0">
                <TextBlock Text="SKILLS &amp; CONFIG"
                           Foreground="#CCCCCC"
                           FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" />
                <Button x:Name="BtnRefresh" Content="Refresh"
                        Click="BtnRefresh_Click"
                        HorizontalAlignment="Right"
                        Style="{StaticResource ToolbarBtn}" />
            </DockPanel>

            <!-- Search box -->
            <Border DockPanel.Dock="Top" Margin="12,10,12,6"
                    Background="#1E1E1E" CornerRadius="3"
                    BorderBrush="#3C3C3C" BorderThickness="1"
                    Padding="8,4">
                <Grid>
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Search skills and config..."
                               Foreground="#555555" FontSize="12"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             Foreground="#CCCCCC"
                             CaretBrush="#CCCCCC"
                             BorderThickness="0"
                             FontSize="12"
                             VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <!-- Tree content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="4,0,4,12">
                <StackPanel x:Name="TreePanel" Margin="0,4,0,0">
                    <!-- Content populated in code-behind -->
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" Width="3"
                      Background="#2D2D30"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" />

        <!-- RIGHT PANEL: Content viewer/editor -->
        <Grid Grid.Column="2">
            <!-- Empty state -->
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Path Data="M14,2H6C4.9,2,4,2.9,4,4v16c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V8L14,2z M16,18H8v-2h8V18z M16,14H8v-2h8V14z M13,9V3.5L18.5,9H13z"
                      Fill="#3C3C3C" Width="48" Height="48"
                      Stretch="Uniform" Margin="0,0,0,12" />
                <TextBlock Text="Select a file to view"
                           Foreground="#555555" FontSize="14"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Browse skills, CLAUDE.md files, MCP servers, and settings"
                           Foreground="#444444" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Content viewer -->
            <DockPanel x:Name="ContentPanel" Visibility="Collapsed">

                <!-- Toolbar -->
                <Border DockPanel.Dock="Top" Background="#252526"
                        Padding="12,6" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- File info -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <DockPanel>
                                <TextBlock x:Name="ContentTitle"
                                           Foreground="#CCCCCC" FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border x:Name="ContentScopeBadge"
                                        Style="{StaticResource ScopeBadge}"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="ContentScopeText"
                                               FontSize="10" FontWeight="SemiBold" />
                                </Border>
                            </DockPanel>
                            <TextBlock x:Name="ContentPath"
                                       Foreground="#666666" FontSize="10"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BtnSave" Content="Save"
                                    Click="BtnSave_Click"
                                    Visibility="Collapsed"
                                    Style="{StaticResource ToolbarBtn}"
                                    Background="#007ACC" Foreground="White"
                                    Margin="0,0,6,0" />
                            <Button x:Name="BtnToggleEdit" Content="Edit"
                                    Click="BtnToggleEdit_Click"
                                    Style="{StaticResource ToolbarBtn}"
                                    Margin="0,0,6,0" />
                            <Button x:Name="BtnOpenExternal" Content="Open"
                                    Click="BtnOpenExternal_Click"
                                    Style="{StaticResource ToolbarBtn}"
                                    Margin="0,0,6,0" />
                            <Button x:Name="BtnCopyPath" Content="Copy Path"
                                    Click="BtnCopyPath_Click"
                                    Style="{StaticResource ToolbarBtn}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MCP server detail bar (only for MCP items) -->
                <Border x:Name="McpDetailBar" DockPanel.Dock="Top"
                        Background="#1A2332" Padding="12,8"
                        BorderBrush="#1E3A5F" BorderThickness="0,0,0,1"
                        Visibility="Collapsed">
                    <DockPanel>
                        <Button x:Name="BtnRemoveMcp" Content="Remove Server"
                                Click="BtnRemoveMcp_Click"
                                DockPanel.Dock="Right"
                                Style="{StaticResource DangerBtn}" />
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Command: " Foreground="#6B8EB5" FontSize="11" />
                                <TextBlock x:Name="McpCommandText"
                                           Foreground="#8ECBFF" FontSize="11"
                                           FontFamily="Cascadia Mono, Consolas" />
                            </DockPanel>
                            <DockPanel Margin="0,3,0,0">
                                <TextBlock Text="Args: " Foreground="#6B8EB5" FontSize="11" />
                                <TextBlock x:Name="McpArgsText"
                                           Foreground="#8ECBFF" FontSize="11"
                                           FontFamily="Cascadia Mono, Consolas"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Preview mode: rendered markdown -->
                <FlowDocumentScrollViewer x:Name="PreviewViewer"
                                          Background="#1E1E1E"
                                          VerticalScrollBarVisibility="Auto"
                                          IsToolBarVisible="False" />

                <!-- Editor mode: raw text -->
                <TextBox x:Name="EditorBox"
                         Visibility="Collapsed"
                         FontFamily="Cascadia Mono, Consolas, Courier New"
                         FontSize="13"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         CaretBrush="#D4D4D4"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Padding="20,12"
                         TextChanged="EditorBox_TextChanged" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
