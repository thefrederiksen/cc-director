<Window x:Class="CcDirector.Wpf.WorkflowEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workflow Editor"
        Width="900" Height="700"
        MinWidth="700" MinHeight="500"
        Background="#252526"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Toolbar -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="TitleText" Text="WORKFLOW EDITOR"
                       Foreground="#CCCCCC" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button x:Name="BtnSave" Content="Save" Click="BtnSave_Click"
                    MinWidth="60" Height="28" FontSize="11"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="16,0,0,0" />
            <Button x:Name="BtnUndoAll" Content="Undo All" Click="BtnUndoAll_Click"
                    MinWidth="60" Height="28" FontSize="11"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
            <Button Content="Close" Click="BtnClose_Click"
                    MinWidth="60" Height="28" FontSize="11"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
        </StackPanel>

        <!-- Row 1: Three-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Left: Step list -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="STEPS" Foreground="#888888" FontSize="10"
                           FontWeight="SemiBold" Margin="0,0,0,4" />

                <ListBox x:Name="StepsList" Grid.Row="1"
                         Background="#1E1E1E" Foreground="#CCCCCC"
                         BorderBrush="#3C3C3C" BorderThickness="1"
                         FontSize="11"
                         SelectionChanged="StepsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,2" Height="40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Tiny thumbnail -->
                                <Border Width="44" Height="32"
                                        Background="#1A1A1A" BorderBrush="#3C3C3C"
                                        BorderThickness="1" CornerRadius="2">
                                    <Image Source="{Binding ThumbnailPath}"
                                           Stretch="UniformToFill" />
                                </Border>

                                <!-- Step label -->
                                <StackPanel Grid.Column="1" Margin="4,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StepLabel}"
                                               Foreground="#CCCCCC" FontSize="10"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CommandSummary}"
                                               Foreground="#888888" FontSize="9"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Width="3" Focusable="False"
                          Background="#252526"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" />

            <!-- Center: Step detail -->
            <Grid Grid.Column="2" Margin="8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="STEP DETAIL" Foreground="#888888" FontSize="10"
                           FontWeight="SemiBold" Margin="0,0,0,4" />

                <!-- Param editor area -->
                <Border Grid.Row="1" BorderBrush="#3C3C3C" BorderThickness="1"
                        Background="#1E1E1E">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ParamEditor" Margin="8,8" />
                    </ScrollViewer>
                </Border>

                <!-- Action buttons -->
                <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                    <Button x:Name="BtnDelete" Content="Delete" Click="BtnDelete_Click"
                            MinWidth="60" Height="26" FontSize="11"
                            Background="#3C3C3C" Foreground="#CCCCCC"
                            BorderThickness="0" Cursor="Hand" />
                    <Button x:Name="BtnMoveUp" Content="Move Up" Click="BtnMoveUp_Click"
                            MinWidth="60" Height="26" FontSize="11"
                            Background="#3C3C3C" Foreground="#CCCCCC"
                            BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
                    <Button x:Name="BtnMoveDown" Content="Move Down" Click="BtnMoveDown_Click"
                            MinWidth="60" Height="26" FontSize="11"
                            Background="#3C3C3C" Foreground="#CCCCCC"
                            BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
                    <Button x:Name="BtnDuplicate" Content="Duplicate" Click="BtnDuplicate_Click"
                            MinWidth="60" Height="26" FontSize="11"
                            Background="#3C3C3C" Foreground="#CCCCCC"
                            BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
                    <Button x:Name="BtnAddCondition" Content="Add Condition" Click="BtnAddCondition_Click"
                            MinWidth="80" Height="26" FontSize="11"
                            Background="#007ACC" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
                </WrapPanel>
            </Grid>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Width="3" Focusable="False"
                          Background="#252526"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" />

            <!-- Right: Screenshot preview -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="SCREENSHOT" Foreground="#888888" FontSize="10"
                           FontWeight="SemiBold" Margin="0,0,0,4" />

                <Border Grid.Row="1" BorderBrush="#3C3C3C" BorderThickness="1"
                        Background="#1A1A1A" CornerRadius="2"
                        MouseLeftButtonDown="ScreenshotPreview_DoubleClick">
                    <Image x:Name="ScreenshotPreview" Stretch="Uniform" />
                </Border>

                <TextBlock x:Name="ScreenshotLabel" Grid.Row="2"
                           Foreground="#666666" FontSize="9"
                           Margin="0,4,0,0" />
            </Grid>
        </Grid>
    </Grid>
</Window>
