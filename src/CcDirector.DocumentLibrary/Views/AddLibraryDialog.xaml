<Window x:Class="CcDirector.DocumentLibrary.Views.AddLibraryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Document Library"
        SizeToContent="Height" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#252526"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Path -->
        <TextBlock Grid.Row="0" Text="Path:"
                   Foreground="#CCCCCC" FontSize="13"
                   VerticalAlignment="Center" Margin="0,0,8,8" />
        <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Browse..."
                    Click="BtnBrowse_Click"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Height="28" Padding="10,4" Margin="8,0,0,0" />
            <TextBox x:Name="TxtPath"
                     Background="#3C3C3C" Foreground="#CCCCCC"
                     BorderBrush="#555555" BorderThickness="1"
                     Padding="6,4" FontSize="13"
                     VerticalContentAlignment="Center" />
        </DockPanel>

        <!-- Label -->
        <TextBlock Grid.Row="1" Text="Label:"
                   Foreground="#CCCCCC" FontSize="13"
                   VerticalAlignment="Center" Margin="0,0,8,8" />
        <TextBox x:Name="TxtLabel" Grid.Row="1" Grid.Column="1"
                 Background="#3C3C3C" Foreground="#CCCCCC"
                 BorderBrush="#555555" BorderThickness="1"
                 Padding="6,4" FontSize="13" Margin="0,0,0,8"
                 VerticalContentAlignment="Center" />

        <!-- Category -->
        <TextBlock Grid.Row="2" Text="Category:"
                   Foreground="#CCCCCC" FontSize="13"
                   VerticalAlignment="Center" Margin="0,0,8,8" />
        <ComboBox x:Name="CmbCategory" Grid.Row="2" Grid.Column="1"
                  Background="#3C3C3C" Foreground="#CCCCCC"
                  BorderBrush="#555555" BorderThickness="1"
                  Height="28" Margin="0,0,0,8"
                  SelectedIndex="0">
            <ComboBoxItem Content="business" />
            <ComboBoxItem Content="personal" />
            <ComboBoxItem Content="other" />
        </ComboBox>

        <!-- Owner -->
        <TextBlock Grid.Row="3" Text="Owner:"
                   Foreground="#CCCCCC" FontSize="13"
                   VerticalAlignment="Center" Margin="0,0,8,8" />
        <TextBox x:Name="TxtOwner" Grid.Row="3" Grid.Column="1"
                 Background="#3C3C3C" Foreground="#CCCCCC"
                 BorderBrush="#555555" BorderThickness="1"
                 Padding="6,4" FontSize="13" Margin="0,0,0,16"
                 VerticalContentAlignment="Center" />

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel" Click="BtnCancel_Click"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Height="30" Width="80" Margin="0,0,8,0" />
            <Button Content="Add Library" Click="BtnAdd_Click"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Height="30" Width="100" />
        </StackPanel>
    </Grid>
</Window>
