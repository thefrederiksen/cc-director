<Window x:Class="CcDirector.DocumentLibrary.Views.ScanProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Processing..."
        Width="460" Height="220"
        WindowStartupLocation="CenterOwner"
        Background="#252526"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Phase title -->
        <TextBlock x:Name="PhaseTitle"
                   Foreground="#CCCCCC" FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Progress bar -->
        <ProgressBar x:Name="Progress" Grid.Row="1"
                     Height="18" Margin="0,0,0,8"
                     Background="#3C3C3C"
                     Foreground="#007ACC"
                     Minimum="0" Maximum="100" Value="0" />

        <!-- Current file -->
        <TextBlock x:Name="CurrentFile" Grid.Row="2"
                   Foreground="#808080" FontSize="11"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,8" />

        <!-- Stats -->
        <TextBlock x:Name="StatsText" Grid.Row="3"
                   Foreground="#CCCCCC" FontSize="12"
                   Margin="0,0,0,8" />

        <!-- Cancel button -->
        <Button x:Name="BtnCancel" Grid.Row="5"
                Content="Cancel"
                Click="BtnCancel_Click"
                Background="#3C3C3C" Foreground="#CCCCCC"
                BorderThickness="0" Cursor="Hand"
                Height="30" Width="80"
                HorizontalAlignment="Right" />
    </Grid>
</Window>
