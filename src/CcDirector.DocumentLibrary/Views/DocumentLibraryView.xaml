<UserControl x:Class="CcDirector.DocumentLibrary.Views.DocumentLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CcDirector.DocumentLibrary.Views"
             Background="#1E1E1E">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="SidebarBg" Color="#252526" />
        <SolidColorBrush x:Key="BorderColor" Color="#3C3C3C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC" />
        <SolidColorBrush x:Key="TextSecondary" Color="#808080" />

        <Style x:Key="FilterChipStyle" TargetType="Button">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="FilterChipActiveStyle" TargetType="Button">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <!-- TreeView: transparent background -->
        <Style x:Key="LibraryTreeViewStyle" TargetType="TreeView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- TreeViewItem: light text, dark theme, expand/collapse -->
        <Style x:Key="LibraryTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="IsExpanded" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    Padding="4,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Width="16" Height="16"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Cursor="Hand"
                                                  Visibility="Collapsed">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="16">
                                                    <TextBlock x:Name="Arrow" Text=">" FontSize="10"
                                                               Foreground="#808080"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Text" Value="v" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Margin="2,0,0,0" />
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Expander" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid dark theme styles -->
        <Style x:Key="CatalogDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="#1E1E1E" />
            <Setter Property="AlternatingRowBackground" Value="#222222" />
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2A2A" />
            <Setter Property="VerticalGridLinesBrush" Value="#2A2A2A" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="RowHeight" Value="26" />
        </Style>

        <Style x:Key="CatalogColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#808080" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="CatalogCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CatalogRowStyle" TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button x:Name="BtnBack" DockPanel.Dock="Left"
                        Content="&lt; Back"
                        Click="BtnBack_Click"
                        Background="Transparent" Foreground="#808080"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="12" Padding="4,2" Margin="0,0,12,0" />

                <TextBlock Text="DOCUMENT LIBRARY"
                           Foreground="#CCCCCC"
                           FontWeight="SemiBold" FontSize="14"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock x:Name="StatusBar"
                       Text="{Binding StatusText}"
                       Foreground="#808080" FontSize="11" />
        </Border>

        <!-- TabControl with Search and Libraries tabs -->
        <TabControl x:Name="MainTabs" Background="#1E1E1E" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D2D" />
                    <Setter Property="Foreground" Value="#888888" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="12,6" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                        <Border x:Name="BottomAccent"
                                                Height="2"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,0,-6"
                                                Background="Transparent" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1E1E1E" />
                                        <Setter Property="Foreground" Value="#CCCCCC" />
                                        <Setter TargetName="BottomAccent" Property="Background" Value="#007ACC" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ==================== SEARCH TAB ==================== -->
            <TabItem Header="Search">
                <DockPanel Background="#1E1E1E">
                    <!-- Search bar + filter chips -->
                    <Border DockPanel.Dock="Top" Background="#252526"
                            BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                            Padding="16,8">
                        <StackPanel>
                            <Grid>
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#3C3C3C" Foreground="#CCCCCC"
                                         BorderBrush="#555555" BorderThickness="1"
                                         Padding="8,6" FontSize="13"
                                         VerticalContentAlignment="Center"
                                         TextChanged="SearchBox_TextChanged" />
                                <TextBlock x:Name="SearchPlaceholder"
                                           Text="Search files by name, title, tags..."
                                           Foreground="#808080" FontSize="13"
                                           Padding="10,7" IsHitTestVisible="False" />
                            </Grid>

                            <StackPanel x:Name="SearchFilterBar" Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="All" Tag="" Click="SearchFilterChip_Click"
                                        Style="{StaticResource FilterChipActiveStyle}" />
                                <Button Content=".pdf" Tag=".pdf" Click="SearchFilterChip_Click"
                                        Style="{StaticResource FilterChipStyle}" />
                                <Button Content=".docx" Tag=".docx" Click="SearchFilterChip_Click"
                                        Style="{StaticResource FilterChipStyle}" />
                                <Button Content=".pptx" Tag=".pptx" Click="SearchFilterChip_Click"
                                        Style="{StaticResource FilterChipStyle}" />
                                <Button Content=".xlsx" Tag=".xlsx" Click="SearchFilterChip_Click"
                                        Style="{StaticResource FilterChipStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Search results grid + preview pane -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="PreviewSplitterCol" Width="0" />
                            <ColumnDefinition x:Name="PreviewCol" Width="0" />
                        </Grid.ColumnDefinitions>

                        <!-- Search results DataGrid -->
                        <DataGrid x:Name="SearchGrid" Grid.Column="0"
                                  ItemsSource="{Binding SearchResults}"
                                  SelectedItem="{Binding SelectedSearchEntry}"
                                  Style="{StaticResource CatalogDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource CatalogColumnHeaderStyle}"
                                  CellStyle="{StaticResource CatalogCellStyle}"
                                  RowStyle="{StaticResource CatalogRowStyle}"
                                  SelectionChanged="SearchGrid_SelectionChanged"
                                  MouseDoubleClick="SearchGrid_DoubleClick"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="EXT" Binding="{Binding FileExt}"
                                                    Width="60" SortMemberPath="FileExt" />
                                <DataGridTextColumn Header="NAME" Binding="{Binding FileName}"
                                                    Width="*" SortMemberPath="FileName">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="ToolTip" Value="{Binding FilePath}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="FOLDER" Binding="{Binding Department}"
                                                    Width="120" SortMemberPath="Department">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#808080" />
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="SIZE" Binding="{Binding FileSizeDisplay}"
                                                    Width="80" SortMemberPath="FileSize">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#808080" />
                                            <Setter Property="TextAlignment" Value="Right" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Splitter between grid and preview -->
                        <GridSplitter x:Name="PreviewSplitter" Grid.Column="1"
                                      Width="3" HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="#3C3C3C"
                                      Visibility="Collapsed" />

                        <!-- Preview pane -->
                        <Border x:Name="PreviewPane" Grid.Column="2"
                                Background="#252526" BorderBrush="#3C3C3C"
                                BorderThickness="1,0,0,0"
                                Visibility="Collapsed">
                            <DockPanel>
                                <!-- Preview header -->
                                <Border DockPanel.Dock="Top" Background="#2D2D2D"
                                        Padding="12,8">
                                    <DockPanel>
                                        <Button x:Name="BtnClosePreview" DockPanel.Dock="Right"
                                                Content="X" Click="BtnClosePreview_Click"
                                                Background="Transparent" Foreground="#808080"
                                                BorderThickness="0" Cursor="Hand"
                                                FontSize="12" FontWeight="Bold"
                                                Padding="4,0" VerticalAlignment="Top" />

                                        <StackPanel>
                                            <TextBlock x:Name="PreviewTitle"
                                                       Text="" Foreground="#CCCCCC"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock x:Name="PreviewMeta"
                                                       Text="" Foreground="#808080"
                                                       FontSize="11" Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock x:Name="PreviewStatus"
                                                       Text="" Foreground="#808080"
                                                       FontSize="11" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Preview content -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Background="#1E1E1E">
                                    <StackPanel Margin="12,8">
                                        <!-- Summary section -->
                                        <TextBlock x:Name="PreviewSummaryHeader"
                                                   Text="--- Summary ---"
                                                   Foreground="#007ACC" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4"
                                                   Visibility="Collapsed" />
                                        <TextBlock x:Name="PreviewSummary"
                                                   Text="" Foreground="#CCCCCC"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Margin="0,0,0,12"
                                                   Visibility="Collapsed" />

                                        <!-- Content section -->
                                        <TextBlock x:Name="PreviewContentHeader"
                                                   Text="--- Content ---"
                                                   Foreground="#007ACC" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4"
                                                   Visibility="Collapsed" />
                                        <TextBlock x:Name="PreviewContent"
                                                   Text="" Foreground="#999999"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   FontFamily="Consolas"
                                                   Visibility="Collapsed" />
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ==================== LIBRARIES TAB ==================== -->
            <TabItem Header="Libraries">
                <DockPanel Background="#1E1E1E">
                    <!-- Main content: sidebar + grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" MinWidth="160" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Library + Folder tree sidebar -->
                        <Border Grid.Column="0" Background="#252526"
                                BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="LIBRARIES"
                                           Foreground="#808080" FontSize="10"
                                           FontWeight="SemiBold" Margin="12,10,12,6" />

                                <TextBlock x:Name="LoadingText" DockPanel.Dock="Top"
                                           Text="Loading..."
                                           Foreground="#808080" FontSize="11"
                                           Margin="12,4" Visibility="Collapsed" />

                                <TreeView x:Name="LibraryTree"
                                          SelectedItemChanged="LibraryTree_SelectedItemChanged"
                                          Style="{StaticResource LibraryTreeViewStyle}"
                                          ItemContainerStyle="{StaticResource LibraryTreeItemStyle}"
                                          Margin="4,0" />
                            </DockPanel>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1" Width="3"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="#3C3C3C" />

                        <!-- Right panel: toolbar + DataGrid -->
                        <Border Grid.Column="2" Background="#1E1E1E">
                            <DockPanel>
                                <!-- Toolbar with breadcrumb, progress bar, Add Library and Scan+Summarize -->
                                <Border DockPanel.Dock="Top" Background="#252526"
                                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                                        Padding="12,6">
                                    <DockPanel>
                                        <Button x:Name="BtnAddLibrary" DockPanel.Dock="Right"
                                                Content="+ Add Library"
                                                Click="BtnAddLibrary_Click"
                                                Background="#007ACC" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Height="26" Padding="12,2" FontSize="11"
                                                Margin="8,0,0,0" />

                                        <Button x:Name="BtnRemoveLibrary" DockPanel.Dock="Right"
                                                Content="Remove Library"
                                                Click="BtnRemoveLibrary_Click"
                                                Background="#C42B1C" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Height="26" Padding="12,2" FontSize="11"
                                                Margin="8,0,0,0"
                                                Visibility="Collapsed" />

                                        <Button x:Name="BtnScanAndSummarize" DockPanel.Dock="Right"
                                                Content="Scan + Summarize"
                                                Click="BtnScanAndSummarize_Click"
                                                Background="#3C3C3C" Foreground="#CCCCCC"
                                                BorderThickness="0" Cursor="Hand"
                                                Height="26" Padding="12,2" FontSize="11"
                                                Visibility="Collapsed" />

                                        <!-- Scan progress (visible only during scan) -->
                                        <StackPanel x:Name="ScanProgressPanel" DockPanel.Dock="Right"
                                                    Orientation="Horizontal" Margin="0,0,12,0"
                                                    Visibility="Collapsed"
                                                    VerticalAlignment="Center">
                                            <ProgressBar x:Name="ScanProgressBar"
                                                         Width="140" Height="4"
                                                         Minimum="0" Maximum="100" Value="0"
                                                         Foreground="#007ACC"
                                                         Background="#3C3C3C"
                                                         BorderThickness="0"
                                                         VerticalAlignment="Center" />
                                            <TextBlock x:Name="ScanProgressText"
                                                       Text=""
                                                       Foreground="#808080" FontSize="11"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       MaxWidth="250"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button x:Name="BtnCancelScan"
                                                    Content="Cancel"
                                                    Click="BtnCancelScan_Click"
                                                    Background="#3C3C3C" Foreground="#CCCCCC"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Height="20" Padding="8,0" FontSize="11"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center" />
                                        </StackPanel>

                                        <TextBlock x:Name="BreadcrumbText"
                                                   Text="Select a library"
                                                   Foreground="#808080" FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>

                                <!-- Filter bar for Libraries tab -->
                                <Border DockPanel.Dock="Top" Background="#252526"
                                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                                        Padding="12,4">
                                    <StackPanel x:Name="FilterBar" Orientation="Horizontal">
                                        <Button Content="All" Tag="" Click="FilterChip_Click"
                                                Style="{StaticResource FilterChipActiveStyle}" />
                                        <Button Content=".pdf" Tag=".pdf" Click="FilterChip_Click"
                                                Style="{StaticResource FilterChipStyle}" />
                                        <Button Content=".docx" Tag=".docx" Click="FilterChip_Click"
                                                Style="{StaticResource FilterChipStyle}" />
                                        <Button Content=".pptx" Tag=".pptx" Click="FilterChip_Click"
                                                Style="{StaticResource FilterChipStyle}" />
                                        <Button Content=".xlsx" Tag=".xlsx" Click="FilterChip_Click"
                                                Style="{StaticResource FilterChipStyle}" />
                                    </StackPanel>
                                </Border>

                                <!-- DataGrid for catalog entries -->
                                <DataGrid x:Name="CatalogGrid"
                                          ItemsSource="{Binding Entries}"
                                          SelectedItem="{Binding SelectedEntry}"
                                          Style="{StaticResource CatalogDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource CatalogColumnHeaderStyle}"
                                          CellStyle="{StaticResource CatalogCellStyle}"
                                          RowStyle="{StaticResource CatalogRowStyle}"
                                          MouseDoubleClick="CatalogGrid_DoubleClick"
                                          Sorting="CatalogGrid_Sorting"
                                          EnableColumnVirtualization="True"
                                          EnableRowVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="EXT" Binding="{Binding FileExt}"
                                                            Width="60" SortMemberPath="FileExt" />
                                        <DataGridTextColumn Header="NAME" Binding="{Binding FileName}"
                                                            Width="*" SortMemberPath="FileName">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                    <Setter Property="ToolTip" Value="{Binding FilePath}" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="FOLDER" Binding="{Binding Department}"
                                                            Width="120" SortMemberPath="Department">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#808080" />
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="SIZE" Binding="{Binding FileSizeDisplay}"
                                                            Width="80" SortMemberPath="FileSize">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#808080" />
                                                    <Setter Property="TextAlignment" Value="Right" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="MODIFIED" Binding="{Binding ModifiedDisplay}"
                                                            Width="130" SortMemberPath="FileModifiedAt">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#808080" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="STATUS" Binding="{Binding StatusDisplay}"
                                                            Width="70" SortMemberPath="Status">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="FontSize" Value="10" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
