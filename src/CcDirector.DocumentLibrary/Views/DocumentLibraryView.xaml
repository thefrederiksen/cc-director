<UserControl x:Class="CcDirector.DocumentLibrary.Views.DocumentLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CcDirector.DocumentLibrary.Views"
             Background="#1E1E1E">

    <UserControl.Resources>
        <!-- Reusable styles matching VisualStyle.md -->
        <SolidColorBrush x:Key="PanelBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="SidebarBg" Color="#252526" />
        <SolidColorBrush x:Key="BorderColor" Color="#3C3C3C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC" />
        <SolidColorBrush x:Key="TextSecondary" Color="#808080" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterChipStyle" TargetType="Button">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="FilterChipActiveStyle" TargetType="Button">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button x:Name="BtnBack" DockPanel.Dock="Left"
                        Content="&lt; Back"
                        Click="BtnBack_Click"
                        Background="Transparent" Foreground="#808080"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="12" Padding="4,2" Margin="0,0,12,0" />

                <Button x:Name="BtnAddLibrary" DockPanel.Dock="Right"
                        Content="+ Add Library"
                        Click="BtnAddLibrary_Click"
                        Background="#007ACC" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Height="28" Padding="12,4" FontSize="12" />

                <TextBlock Text="DOCUMENT LIBRARY"
                           Foreground="#CCCCCC"
                           FontWeight="SemiBold" FontSize="14"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Search and filter bar -->
        <Border DockPanel.Dock="Top" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel>
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3C3C3C" Foreground="#CCCCCC"
                         BorderBrush="#555555" BorderThickness="1"
                         Padding="8,6" FontSize="13"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Tag" Value="Search documents..." />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <StackPanel x:Name="FilterBar" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="All" Tag="" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipActiveStyle}" />
                    <Button Content=".pdf" Tag=".pdf" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                    <Button Content=".docx" Tag=".docx" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                    <Button Content=".pptx" Tag=".pptx" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                    <Button Content=".xlsx" Tag=".xlsx" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock x:Name="StatusBar"
                       Text="{Binding StatusText}"
                       Foreground="#808080" FontSize="11" />
        </Border>

        <!-- Main content: library sidebar + catalog list -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Library sidebar -->
            <Border Grid.Column="0" Background="#252526"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="LIBRARIES"
                               Foreground="#808080" FontSize="10"
                               FontWeight="SemiBold" Margin="12,10,12,6" />

                    <TextBlock x:Name="LoadingText" DockPanel.Dock="Top"
                               Text="Loading..."
                               Foreground="#808080" FontSize="11"
                               Margin="12,4" Visibility="Collapsed" />

                    <ListBox x:Name="LibraryList"
                             ItemsSource="{Binding Libraries}"
                             SelectedItem="{Binding SelectedLibrary}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#CCCCCC"
                             FontSize="12"
                             Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,4">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="#CCCCCC"
                                                   FontWeight="SemiBold"
                                                   FontSize="12" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Stats.Total, StringFormat='({0})'}"
                                                   Foreground="#808080" FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0,0,0" />
                                    </DockPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Button Content="Scan" Tag="{Binding Label}"
                                                Click="BtnScan_Click"
                                                Style="{StaticResource SidebarButtonStyle}"
                                                Width="55" />
                                        <Button Content="Summarize" Tag="{Binding Label}"
                                                Click="BtnSummarize_Click"
                                                Style="{StaticResource SidebarButtonStyle}"
                                                Width="75" Margin="4,2,0,2" />
                                    </StackPanel>
                                    <TextBlock x:Name="RescanHint"
                                               Foreground="#B8860B" FontSize="9"
                                               Margin="0,2,0,0"
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="#3C3C3C" />

            <!-- Catalog entries -->
            <Border Grid.Column="2" Background="#1E1E1E">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="CATALOG"
                               Foreground="#808080" FontSize="10"
                               FontWeight="SemiBold" Margin="12,10,12,6" />

                    <ListBox x:Name="CatalogList"
                             ItemsSource="{Binding Entries}"
                             SelectedItem="{Binding SelectedEntry}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#CCCCCC"
                             FontSize="13"
                             Padding="8"
                             MouseDoubleClick="CatalogList_DoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,1"
                                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border Background="#3C3C3C" CornerRadius="3"
                                                    Padding="4,1" Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileExt}"
                                                           Foreground="#CCCCCC"
                                                           FontSize="10" FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="#CCCCCC"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <DockPanel Margin="0,3,0,0">
                                            <TextBlock Foreground="#808080" FontSize="10">
                                                <Run Text="{Binding Department, Mode=OneWay, TargetNullValue='-'}" />
                                                <Run Text=" | " />
                                                <Run Text="{Binding FileSizeDisplay, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Summary}"
                                                   Foreground="#999999" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="32"
                                                   Margin="0,3,0,0"
                                                   Visibility="{Binding Summary, Converter={x:Static local:NullToCollapsedConverter.Instance}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
