<UserControl x:Class="CcDirector.DocumentLibrary.Views.DocumentLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CcDirector.DocumentLibrary.Views"
             Background="#1E1E1E">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="SidebarBg" Color="#252526" />
        <SolidColorBrush x:Key="BorderColor" Color="#3C3C3C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC" />
        <SolidColorBrush x:Key="TextSecondary" Color="#808080" />

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterChipStyle" TargetType="Button">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="FilterChipActiveStyle" TargetType="Button">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="SortHeaderStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#808080" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="4,4" />
        </Style>

        <Style x:Key="DeptItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button x:Name="BtnBack" DockPanel.Dock="Left"
                        Content="&lt; Back"
                        Click="BtnBack_Click"
                        Background="Transparent" Foreground="#808080"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="12" Padding="4,2" Margin="0,0,12,0" />

                <Button x:Name="BtnAddLibrary" DockPanel.Dock="Right"
                        Content="+ Add Library"
                        Click="BtnAddLibrary_Click"
                        Background="#007ACC" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Height="28" Padding="12,4" FontSize="12" />

                <TextBlock Text="DOCUMENT LIBRARY"
                           Foreground="#CCCCCC"
                           FontWeight="SemiBold" FontSize="14"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Search and filter bar -->
        <Border DockPanel.Dock="Top" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel>
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3C3C3C" Foreground="#CCCCCC"
                         BorderBrush="#555555" BorderThickness="1"
                         Padding="8,6" FontSize="13"
                         VerticalContentAlignment="Center" />

                <StackPanel x:Name="FilterBar" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="All" Tag="" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipActiveStyle}" />
                    <Button Content=".pdf" Tag=".pdf" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                    <Button Content=".docx" Tag=".docx" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                    <Button Content=".pptx" Tag=".pptx" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                    <Button Content=".xlsx" Tag=".xlsx" Click="FilterChip_Click"
                            Style="{StaticResource FilterChipStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock x:Name="StatusBar"
                       Text="{Binding StatusText}"
                       Foreground="#808080" FontSize="11" />
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Library + Department sidebar -->
            <Border Grid.Column="0" Background="#252526"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="LIBRARIES"
                               Foreground="#808080" FontSize="10"
                               FontWeight="SemiBold" Margin="12,10,12,6" />

                    <TextBlock x:Name="LoadingText" DockPanel.Dock="Top"
                               Text="Loading..."
                               Foreground="#808080" FontSize="11"
                               Margin="12,4" Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Library list -->
                            <ItemsControl x:Name="LibraryList"
                                          ItemsSource="{Binding Libraries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="LibBorder" Padding="8,6" Margin="2"
                                                Background="Transparent" Cursor="Hand"
                                                MouseLeftButtonUp="Library_Click">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="#CCCCCC"
                                                               FontWeight="SemiBold"
                                                               FontSize="12" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding Stats.Total, StringFormat='({0})'}"
                                                               Foreground="#808080" FontSize="10"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0" />
                                                </DockPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Button Content="Scan + Summarize" Tag="{Binding Label}"
                                                            Click="BtnScanAndSummarize_Click"
                                                            Style="{StaticResource SidebarButtonStyle}"
                                                            Width="120" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Department list (shown when library selected) -->
                            <TextBlock x:Name="DeptHeader" Text="DEPARTMENTS"
                                       Foreground="#808080" FontSize="10"
                                       FontWeight="SemiBold" Margin="12,12,12,4"
                                       Visibility="Collapsed" />

                            <StackPanel x:Name="DeptPanel" Visibility="Collapsed">
                                <Button Content="All Files" Click="DeptAll_Click"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        HorizontalContentAlignment="Left"
                                        Margin="8,1" Padding="8,3" />

                                <ListBox x:Name="DeptList"
                                         ItemsSource="{Binding Departments}"
                                         SelectionChanged="DeptList_SelectionChanged"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Margin="4,0"
                                         ItemContainerStyle="{StaticResource DeptItemStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="#3C3C3C" />

            <!-- Catalog entries with sort headers -->
            <Border Grid.Column="2" Background="#1E1E1E">
                <DockPanel>
                    <!-- Sort header row -->
                    <Border DockPanel.Dock="Top" Background="#252526"
                            BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                            Padding="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>

                            <Button Content="EXT" Grid.Column="0" Tag="file_ext"
                                    Click="SortHeader_Click"
                                    Style="{StaticResource SortHeaderStyle}" />
                            <Button Content="NAME" Grid.Column="1" Tag="file_name"
                                    Click="SortHeader_Click"
                                    Style="{StaticResource SortHeaderStyle}" />
                            <Button Content="DEPARTMENT" Grid.Column="2" Tag="department"
                                    Click="SortHeader_Click"
                                    Style="{StaticResource SortHeaderStyle}" />
                            <Button Content="SIZE" Grid.Column="3" Tag="file_size"
                                    Click="SortHeader_Click"
                                    Style="{StaticResource SortHeaderStyle}" />
                            <Button Content="MODIFIED" Grid.Column="4" Tag="file_modified_at"
                                    Click="SortHeader_Click"
                                    Style="{StaticResource SortHeaderStyle}" />
                            <Button Content="STATUS" Grid.Column="5" Tag="status"
                                    Click="SortHeader_Click"
                                    Style="{StaticResource SortHeaderStyle}" />
                        </Grid>
                    </Border>

                    <!-- Entry list with virtualization -->
                    <ListBox x:Name="CatalogList"
                             ItemsSource="{Binding Entries}"
                             SelectedItem="{Binding SelectedEntry}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#CCCCCC"
                             FontSize="12"
                             Padding="0"
                             MouseDoubleClick="CatalogList_DoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,3" Height="22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Extension -->
                                    <Border Grid.Column="0" Background="#3C3C3C" CornerRadius="3"
                                            Padding="3,1" Margin="0,0,4,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileExt}"
                                                   Foreground="#CCCCCC"
                                                   FontSize="9" FontWeight="SemiBold" />
                                    </Border>

                                    <!-- File name -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FileName}"
                                               Foreground="#CCCCCC" FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding FilePath}" />

                                    <!-- Department -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Department, TargetNullValue='-'}"
                                               Foreground="#808080" FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" Padding="4,0" />

                                    <!-- Size -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding FileSizeDisplay}"
                                               Foreground="#808080" FontSize="11"
                                               VerticalAlignment="Center" Padding="4,0" />

                                    <!-- Modified date -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding ModifiedDisplay}"
                                               Foreground="#808080" FontSize="11"
                                               VerticalAlignment="Center" Padding="4,0" />

                                    <!-- Status -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding StatusDisplay}"
                                               FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#808080" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="summarized">
                                                        <Setter Property="Foreground" Value="#22C55E" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="error">
                                                        <Setter Property="Foreground" Value="#EF4444" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="missing">
                                                        <Setter Property="Foreground" Value="#F59E0B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
