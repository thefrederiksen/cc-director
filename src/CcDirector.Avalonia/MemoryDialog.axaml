<Window x:Class="CcDirector.Avalonia.MemoryDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CLAUDE.md Memory Files"
        Width="750" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="CLAUDE.md Memory Files"
                   Foreground="#CCCCCC"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Tab Control -->
        <TabControl x:Name="MemoryTabs" Grid.Row="1"
                    Background="#1E1E1E" BorderThickness="0">

            <!-- User CLAUDE.md -->
            <TabItem Header="User CLAUDE.md" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="UserPathText"
                               Text=""
                               Foreground="#666666" FontSize="10"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="UserMemoryText" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C"
                             BorderThickness="1" Padding="8,6"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                    <Button Grid.Row="2" Content="Save" Width="80" Height="28"
                            Background="#007ACC" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right" Margin="0,8,0,0"
                            Click="BtnSaveUser_Click" />
                </Grid>
            </TabItem>

            <!-- Project CLAUDE.md -->
            <TabItem Header="Project CLAUDE.md" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ProjectPathText"
                               Text=""
                               Foreground="#666666" FontSize="10"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="ProjectMemoryText" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C"
                             BorderThickness="1" Padding="8,6"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                    <Button Grid.Row="2" Content="Save" Width="80" Height="28"
                            Background="#007ACC" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right" Margin="0,8,0,0"
                            Click="BtnSaveProject_Click" />
                </Grid>
            </TabItem>

            <!-- Auto-memory MEMORY.md -->
            <TabItem Header="Auto-Memory" Background="#2D2D2D" Foreground="#888888" Padding="12,6">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="AutoMemoryPathText"
                               Text=""
                               Foreground="#666666" FontSize="10"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="AutoMemoryText" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C"
                             BorderThickness="1" Padding="8,6"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                    <Button Grid.Row="2" Content="Save" Width="80" Height="28"
                            Background="#007ACC" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right" Margin="0,8,0,0"
                            Click="BtnSaveAutoMemory_Click" />
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="SaveStatusText" Foreground="#22C55E" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button Content="Close" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
