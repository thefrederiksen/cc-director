<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.WorkflowRunsDialog"
        Title="Workflow Runs"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#252526">

    <Grid Margin="16" ColumnDefinitions="260,3,*">

        <!-- Left: Runs list -->
        <Grid RowDefinitions="Auto,*">

            <TextBlock x:Name="RunsHeader" Text="RUNS"
                       Foreground="#888888" FontSize="10" FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <ListBox x:Name="RunsList" Grid.Row="1"
                     Background="#1E1E1E" Foreground="#CCCCCC"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontSize="11"
                     SelectionChanged="RunsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,4">
                            <TextBlock Text="{Binding DisplayTime}"
                                       Foreground="#CCCCCC" FontSize="11"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{Binding StatusColor}"
                                           FontSize="10" />
                                <TextBlock Text="{Binding StepSummary}"
                                           Foreground="#888888" FontSize="10"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="3"
                      Background="#252526"
                      ResizeDirection="Columns" />

        <!-- Right: Step detail -->
        <Grid Grid.Column="2" Margin="8,0,0,0" RowDefinitions="Auto,Auto,*">

            <TextBlock Text="STEPS" Foreground="#888888" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,8" />

            <!-- Parameter values display -->
            <TextBlock x:Name="ParamValuesText" Grid.Row="1"
                       Foreground="#888888" FontSize="10"
                       TextWrapping="Wrap" Margin="0,0,0,8" />

            <!-- Steps list -->
            <ListBox x:Name="StepsList" Grid.Row="2"
                     Background="#1E1E1E" Foreground="#CCCCCC"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontSize="11"
                     DoubleTapped="StepsList_DoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,4" ColumnDefinitions="60,*,Auto,Auto">

                            <!-- Thumbnail placeholder -->
                            <Border Width="50" Height="35"
                                    Background="#1A1A1A" BorderBrush="#3C3C3C"
                                    BorderThickness="1" CornerRadius="2">
                                <Image Source="{Binding ThumbnailPath}"
                                       Stretch="UniformToFill" />
                            </Border>

                            <!-- Command + params -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding CommandDisplay}"
                                           Foreground="#CCCCCC" FontSize="11"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ParamsDisplay}"
                                           Foreground="#888888" FontSize="10"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Status -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding StatusText}"
                                       Foreground="{Binding StatusColor}"
                                       FontSize="10" VerticalAlignment="Center"
                                       Margin="8,0,0,0" />

                            <!-- Duration -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding DurationDisplay}"
                                       Foreground="#666666" FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
