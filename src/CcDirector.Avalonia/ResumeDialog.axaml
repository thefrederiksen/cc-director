<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.ResumeDialog"
        Title="Resume Session"
        Width="650" Height="500"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select a session to resume:"
                   Foreground="#CCCCCC"
                   FontSize="14"
                   Margin="0,0,0,10" />

        <TextBlock x:Name="LoadingText"
                   Grid.Row="1"
                   Text="Loading..."
                   Foreground="#888888"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <ListBox x:Name="SessionList"
                 Grid.Row="1"
                 Background="#1E1E1E"
                 BorderBrush="#3C3C3C"
                 BorderThickness="1"
                 Foreground="#CCCCCC"
                 IsVisible="False"
                 DoubleTapped="SessionList_DoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,6,4,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding FileName}"
                                   Foreground="#CCCCCC"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding LastModified}"
                                       Foreground="#888888"
                                       FontSize="11" />
                            <TextBlock Text="  --  "
                                       Foreground="#555555"
                                       FontSize="11" />
                            <TextBlock Text="{Binding FileSize}"
                                       Foreground="#888888"
                                       FontSize="11" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BtnOk"
                    Content="OK"
                    Width="90" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsEnabled="False"
                    Click="BtnOk_Click" />
            <Button x:Name="BtnCancel"
                    Content="Cancel"
                    Width="90" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="8,0,0,0"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
