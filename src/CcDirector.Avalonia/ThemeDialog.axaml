<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.ThemeDialog"
        Title="Claude Code Theme"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Color Theme"
                   Foreground="#CCCCCC"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="1"
                   Text="Select a theme for Claude Code terminal output"
                   Foreground="#888888"
                   FontSize="11"
                   Margin="0,0,0,16" />

        <!-- Theme list -->
        <ItemsControl x:Name="ThemeList" Grid.Row="2">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1E1E1E"
                            BorderBrush="{Binding BorderBrushColor}"
                            BorderThickness="{Binding BorderThicknessValue}"
                            CornerRadius="4"
                            Margin="0,0,0,6"
                            Padding="12,10"
                            Cursor="Hand"
                            PointerPressed="ThemeItem_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Color swatch -->
                            <Border Width="24" Height="24"
                                    CornerRadius="4"
                                    Background="{Binding SwatchColor}"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1" />

                            <!-- Theme name -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayName}"
                                       Foreground="#CCCCCC"
                                       FontSize="13"
                                       VerticalAlignment="Center" />

                            <!-- Current indicator -->
                            <TextBlock Grid.Column="2"
                                       Text="(current)"
                                       Foreground="#007ACC"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsCurrent}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True"
                    Click="BtnOk_Click" />
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True"
                    Click="BtnCancel_Click" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
