<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.StatusDialog"
        Title="Claude Code Status"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Claude Code Status"
                   Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <TextBlock x:Name="LoadingText" Grid.Row="1"
                   Text="Loading..."
                   Foreground="#888888" FontSize="12" FontStyle="Italic"
                   Margin="0,0,0,12" />

        <Grid x:Name="StatusGrid" Grid.Row="1" IsVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:"
                       Foreground="#888888" FontSize="13" Margin="0,0,0,10" />
            <TextBlock x:Name="VersionText" Grid.Row="0" Grid.Column="1" Text="-"
                       Foreground="#CCCCCC" FontSize="13"
                       FontFamily="Cascadia Mono, Consolas" Margin="0,0,0,10" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Account:"
                       Foreground="#888888" FontSize="13" Margin="0,0,0,10" />
            <TextBlock x:Name="AccountNameText" Grid.Row="1" Grid.Column="1" Text="-"
                       Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,10" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:"
                       Foreground="#888888" FontSize="13" Margin="0,0,0,10" />
            <TextBlock x:Name="EmailText" Grid.Row="2" Grid.Column="1" Text="-"
                       Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,10" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Install Method:"
                       Foreground="#888888" FontSize="13" Margin="0,0,0,10" />
            <TextBlock x:Name="InstallMethodText" Grid.Row="3" Grid.Column="1" Text="-"
                       Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,10" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Startups:"
                       Foreground="#888888" FontSize="13" Margin="0,0,0,10" />
            <TextBlock x:Name="StartupsText" Grid.Row="4" Grid.Column="1" Text="-"
                       Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,10" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
