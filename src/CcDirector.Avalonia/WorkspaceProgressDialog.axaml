<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.WorkspaceProgressDialog"
        Title="Loading Workspace"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="#252526">

    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto">

        <!-- Status message -->
        <TextBlock Grid.Row="0"
                   x:Name="StatusText"
                   Text="Loading workspace..."
                   Foreground="#CCCCCC"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1"
                     x:Name="ProgressBar"
                     Height="4"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Background="#3C3C3C"
                     Foreground="#007ACC"
                     Margin="0,0,0,8" />

        <!-- Detail text -->
        <TextBlock Grid.Row="2"
                   x:Name="DetailText"
                   Text=""
                   Foreground="#888888"
                   FontSize="12"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
