<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CcDirector.Avalonia.Controls.SessionBrowserView"
             Background="{DynamicResource PanelBackground}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="8,6"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnRefresh" Content="Refresh" DockPanel.Dock="Right"
                        Click="BtnRefresh_Click"
                        Background="Transparent" Foreground="#888888"
                        BorderThickness="0" FontSize="11" Cursor="Hand"
                        Padding="6,2" />
                <TextBlock Text="SESSIONS"
                           Foreground="#888888" FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Search box -->
        <Border DockPanel.Dock="Top" Padding="8,4"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <TextBox x:Name="SearchBox"
                     Watermark="Search sessions..."
                     Background="#3C3C3C"
                     Foreground="{DynamicResource TextForeground}"
                     BorderThickness="0"
                     Padding="6,4"
                     FontSize="12"
                     TextChanged="SearchBox_TextChanged" />
        </Border>

        <!-- Loading text -->
        <TextBlock x:Name="LoadingText"
                   Text="Loading..."
                   Foreground="#888888" FontSize="12"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="False" />

        <!-- Empty text -->
        <TextBlock x:Name="EmptyText"
                   Text="No sessions found"
                   Foreground="#555555" FontSize="12"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="False" />

        <!-- Session tree -->
        <ScrollViewer x:Name="ContentScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="TreeContainer" Margin="4" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
