<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.Controls.CommManager.ScheduleDialog"
        Title="Schedule Send"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto">

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="When should this be sent?"
                   Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- Timing Options -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,12">
            <RadioButton x:Name="AsapOption" GroupName="Timing" IsChecked="True"
                         Foreground="#CCCCCC">
                <RadioButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Send ASAP" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="  --  Dispatch immediately" Foreground="#888888" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton.Content>
            </RadioButton>

            <RadioButton x:Name="TomorrowMorningOption" GroupName="Timing"
                         Foreground="#CCCCCC">
                <RadioButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tomorrow morning" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock x:Name="TomorrowMorningLabel" Text="" Foreground="#888888" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </RadioButton.Content>
            </RadioButton>

            <RadioButton x:Name="TomorrowAfternoonOption" GroupName="Timing"
                         Foreground="#CCCCCC">
                <RadioButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tomorrow afternoon" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock x:Name="TomorrowAfternoonLabel" Text="" Foreground="#888888" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </RadioButton.Content>
            </RadioButton>

            <RadioButton x:Name="ScheduleOption" GroupName="Timing"
                         Foreground="#CCCCCC">
                <TextBlock Text="Schedule for..." Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
            </RadioButton>

            <RadioButton x:Name="HoldOption" GroupName="Timing"
                         Foreground="#CCCCCC">
                <RadioButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Hold" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="  --  Approve but don't auto-send" Foreground="#888888" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton.Content>
            </RadioButton>
        </StackPanel>

        <!-- Custom Date/Time Picker -->
        <Border x:Name="DateTimePanel" Grid.Row="2" Background="#1E1E1E" CornerRadius="4"
                Padding="12" Margin="0,0,0,12" IsVisible="False">
            <StackPanel>
                <TextBlock Text="Pick date and time" Foreground="#888888" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Date Picker -->
                <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="Date:" Foreground="#AAAAAA" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CalendarDatePicker x:Name="ScheduleDatePicker" Grid.Column="1"
                                        Background="#333333" Foreground="#CCCCCC"
                                        BorderBrush="#555555" BorderThickness="1"
                                        HorizontalAlignment="Stretch"/>
                </Grid>

                <!-- Quick Time Presets -->
                <TextBlock Text="Quick times:" Foreground="#888888" FontSize="11" Margin="0,4,0,4"/>
                <WrapPanel Margin="0,0,0,8">
                    <Button Content="9:00 AM" Tag="09:00" Click="TimePreset_Click"
                            Background="#333333" Foreground="#CCCCCC" Padding="10,6" Margin="2"
                            FontSize="12" Cursor="Hand" BorderThickness="0" CornerRadius="4"/>
                    <Button Content="10:00 AM" Tag="10:00" Click="TimePreset_Click"
                            Background="#333333" Foreground="#CCCCCC" Padding="10,6" Margin="2"
                            FontSize="12" Cursor="Hand" BorderThickness="0" CornerRadius="4"/>
                    <Button Content="12:00 PM" Tag="12:00" Click="TimePreset_Click"
                            Background="#333333" Foreground="#CCCCCC" Padding="10,6" Margin="2"
                            FontSize="12" Cursor="Hand" BorderThickness="0" CornerRadius="4"/>
                    <Button Content="2:00 PM" Tag="14:00" Click="TimePreset_Click"
                            Background="#333333" Foreground="#CCCCCC" Padding="10,6" Margin="2"
                            FontSize="12" Cursor="Hand" BorderThickness="0" CornerRadius="4"/>
                    <Button Content="3:00 PM" Tag="15:00" Click="TimePreset_Click"
                            Background="#333333" Foreground="#CCCCCC" Padding="10,6" Margin="2"
                            FontSize="12" Cursor="Hand" BorderThickness="0" CornerRadius="4"/>
                    <Button Content="5:00 PM" Tag="17:00" Click="TimePreset_Click"
                            Background="#333333" Foreground="#CCCCCC" Padding="10,6" Margin="2"
                            FontSize="12" Cursor="Hand" BorderThickness="0" CornerRadius="4"/>
                    <Button Content="6:00 PM" Tag="18:00" Click="TimePreset_Click"
                            Background="#333333" Foreground="#CCCCCC" Padding="10,6" Margin="2"
                            FontSize="12" Cursor="Hand" BorderThickness="0" CornerRadius="4"/>
                </WrapPanel>

                <!-- Custom Time Input -->
                <Grid ColumnDefinitions="Auto,60,Auto,60,Auto,60">
                    <TextBlock Grid.Column="0" Text="Time:" Foreground="#AAAAAA" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="HourBox" Grid.Column="1" Text="9"
                             Background="#333333" Foreground="#CCCCCC" BorderBrush="#555555"
                             Padding="4" MaxLength="2"/>
                    <TextBlock Grid.Column="2" Text=":" Foreground="#AAAAAA" FontSize="14"
                               VerticalAlignment="Center" Margin="4,0"/>
                    <TextBox x:Name="MinuteBox" Grid.Column="3" Text="00"
                             Background="#333333" Foreground="#CCCCCC" BorderBrush="#555555"
                             Padding="4" MaxLength="2"/>
                    <ComboBox x:Name="AmPmBox" Grid.Column="5"
                              Background="#333333" Foreground="#CCCCCC" BorderBrush="#555555"
                              SelectedIndex="0">
                        <ComboBoxItem Content="AM"/>
                        <ComboBoxItem Content="PM"/>
                    </ComboBox>
                </Grid>

                <!-- Schedule summary -->
                <TextBlock x:Name="ScheduleSummary" Text="" Foreground="#007ACC" FontSize="12"
                           FontWeight="SemiBold" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button x:Name="ConfirmButton" Content="Approve" Width="120" Height="28"
                    Background="#28A745" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
