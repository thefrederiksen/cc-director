<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CcDirector.Avalonia.Controls.UsageDashboardView"
             Background="#1E1E1E">

    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
            <TextBlock Text="USAGE"
                       Foreground="#CCCCCC"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center" />

            <Button x:Name="BtnRefresh"
                    Content="Refresh"
                    Click="BtnRefresh_Click"
                    HorizontalAlignment="Right"
                    Height="28"
                    Padding="12,0"
                    Background="#3C3C3C"
                    Foreground="#CCCCCC"
                    BorderThickness="0"
                    Cursor="Hand" />
        </DockPanel>

        <!-- Loading text -->
        <TextBlock x:Name="LoadingText"
                   Text="Loading..."
                   Foreground="#888888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   DockPanel.Dock="Top"
                   Margin="0,40,0,0" />

        <!-- Content -->
        <ScrollViewer x:Name="ContentScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      IsVisible="False"
                      Padding="16,0,16,16">
            <StackPanel x:Name="ContentPanel" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
