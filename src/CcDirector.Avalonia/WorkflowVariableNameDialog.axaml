<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.WorkflowVariableNameDialog"
        Title="Set Variable"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Current value: " Foreground="#888888" FontSize="11" />
            <TextBlock x:Name="CurrentValueText" Foreground="#CCCCCC" FontSize="11" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Variable name (e.g. comment_text):"
                   Foreground="#CCCCCC" FontSize="12"
                   Margin="0,8,0,4" />

        <TextBox x:Name="VarNameBox" Grid.Row="2"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 BorderBrush="#3C3C3C"
                 BorderThickness="1" Padding="8,6"
                 FontSize="12" FontFamily="Cascadia Mono,Consolas,monospace" />

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnOK_Click" />
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Margin="8,0,0,0"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
