<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.WorkflowConfirmDialog"
        Title="Start Workflow Recording"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <StackPanel Margin="20">
        <TextBlock Text="WORKFLOW RECORDER"
                   Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="14"
                   Margin="0,0,0,12" />

        <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="12"
                   Margin="0,0,0,8">
            The workflow recorder needs exclusive control of the browser window.
        </TextBlock>

        <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="12"
                   Margin="0,0,0,8">
            Before starting, please close all Brave browser windows manually.
            The recorder will then launch a fresh browser positioned on the
            right side of your screen, with the recording panel on the left.
        </TextBlock>

        <TextBlock TextWrapping="Wrap" Foreground="#888888" FontSize="11"
                   FontStyle="Italic" Margin="0,0,0,16">
            If this connection is currently open, it will be closed and
            reopened in the correct position.
        </TextBlock>

        <!-- Buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Start" Width="80"
                    Click="BtnStart_Click"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Height="28"
                    Margin="0,0,8,0" />
            <Button Grid.Column="2" Content="Cancel" Width="80"
                    Click="BtnCancel_Click"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" Height="28" />
        </Grid>
    </StackPanel>
</Window>
