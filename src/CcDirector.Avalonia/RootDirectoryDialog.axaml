<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.RootDirectoryDialog"
        Title="Add Root Directory"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <StackPanel Margin="20">
        <TextBlock Text="Label" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4" />
        <TextBox x:Name="LabelInput"
                 Background="#1E1E1E" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                 BorderBrush="#3C3C3C" BorderThickness="1"
                 Padding="8,6" FontSize="13" />

        <TextBlock Text="Root Path" Foreground="#CCCCCC" FontSize="12" Margin="0,16,0,4" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathInput" Grid.Column="0"
                     Background="#1E1E1E" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     Padding="8,6" FontSize="13" />
            <Button Grid.Column="1" Content="Browse..." Click="BtnBrowse_Click"
                    Width="80" Height="30" Margin="8,0,0,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" />
        </Grid>

        <TextBlock Text="Provider" Foreground="#CCCCCC" FontSize="12" Margin="0,16,0,4" />
        <ComboBox x:Name="ProviderCombo"
                  Background="#1E1E1E" Foreground="#CCCCCC"
                  BorderBrush="#3C3C3C" BorderThickness="1"
                  Padding="8,6" FontSize="13"
                  SelectionChanged="ProviderCombo_SelectionChanged">
            <ComboBoxItem Content="GitHub" Tag="GitHub" />
            <ComboBoxItem Content="Azure DevOps" Tag="AzureDevOps" />
            <ComboBoxItem Content="Local Only" Tag="LocalOnly" />
        </ComboBox>

        <StackPanel x:Name="AzureFieldsPanel" IsVisible="False" Margin="0,12,0,0">
            <Border BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="4" Padding="12" Background="#1E1E1E">
                <StackPanel>
                    <TextBlock Text="Azure DevOps Settings" Foreground="#888888" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Organization URL" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4" />
                    <TextBox x:Name="AzureOrgInput"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="8,6" FontSize="13"
                             Text="https://dev.azure.com/" />
                    <TextBlock Text="Project Name" Foreground="#CCCCCC" FontSize="12" Margin="0,12,0,4" />
                    <TextBox x:Name="AzureProjectInput"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="8,6" FontSize="13" />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Click="BtnCancel_Click"
                    Width="80" Height="30" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" />
            <Button Content="Save" Click="BtnSave_Click"
                    Width="80" Height="30"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand" />
        </StackPanel>
    </StackPanel>
</Window>
