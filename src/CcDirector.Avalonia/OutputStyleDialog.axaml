<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.OutputStyleDialog"
        Title="Output Style"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Output Style"
                   Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="1"
                   Text="Choose how Claude formats its responses"
                   Foreground="#888888" FontSize="11"
                   Margin="0,0,0,16" />

        <ComboBox x:Name="StyleCombo" Grid.Row="2"
                  Width="220" HorizontalAlignment="Left"
                  Background="#1E1E1E" Foreground="#CCCCCC"
                  BorderBrush="#3C3C3C"
                  FontSize="13" Padding="8,6" />

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnOk_Click" />
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCancel_Click" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
