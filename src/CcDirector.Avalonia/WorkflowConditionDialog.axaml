<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.WorkflowConditionDialog"
        Title="Add Condition"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

        <!-- Check type -->
        <TextBlock Text="Condition Type" Foreground="#888888" FontSize="10"
                   FontWeight="SemiBold" Margin="0,0,0,4" />

        <ComboBox x:Name="CheckTypeCombo" Grid.Row="1"
                  Background="#1E1E1E" Foreground="#CCCCCC"
                  BorderBrush="#3C3C3C" BorderThickness="1"
                  Height="28" FontSize="11"
                  Margin="0,0,0,12"
                  SelectedIndex="0"
                  SelectionChanged="CheckTypeCombo_SelectionChanged">
            <ComboBoxItem Content="Element Exists" Tag="elementExists" />
            <ComboBoxItem Content="URL Contains" Tag="urlContains" />
            <ComboBoxItem Content="Text Visible" Tag="textVisible" />
        </ComboBox>

        <!-- Selector / Value -->
        <TextBlock x:Name="InputLabel" Grid.Row="2" Text="CSS Selector"
                   Foreground="#888888" FontSize="10"
                   FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBox x:Name="InputBox" Grid.Row="3"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 BorderBrush="#3C3C3C"
                 BorderThickness="1" Padding="8,6"
                 FontSize="11" Margin="0,0,0,16" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnOk_Click" />
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Margin="8,0,0,0"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
