<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.GitHubRepoPickerDialog"
        Title="Browse GitHub Repositories"
        Width="550" Height="450"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter -->
        <TextBox x:Name="FilterBox" Grid.Row="0"
                 Background="#1E1E1E"
                 Foreground="#CCCCCC"
                 CaretBrush="#CCCCCC"
                 BorderBrush="#3C3C3C"
                 Padding="8,6"
                 FontSize="13"
                 Watermark="Filter repositories..."
                 TextChanged="FilterBox_TextChanged" />

        <!-- Repo list -->
        <ListBox x:Name="RepoList" Grid.Row="1"
                 Margin="0,10,0,10"
                 Background="#1E1E1E"
                 BorderBrush="#3C3C3C"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 DoubleTapped="RepoList_DoubleTapped">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="Foreground" Value="#CCCCCC" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="BorderBrush" Value="#333333" />
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="#094771" />
                </Style>
                <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover">
                    <Setter Property="Background" Value="#094771" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   Foreground="#CCCCCC"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <Border Grid.Row="0" Grid.Column="1"
                                Background="{Binding BadgeBackground}"
                                CornerRadius="3"
                                Padding="6,1"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding BadgeText}"
                                       Foreground="{Binding BadgeForeground}"
                                       FontSize="11" />
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding Description}"
                                   Foreground="#888888"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0"
                                   IsVisible="{Binding HasDescription}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Loading / Error / Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText" Grid.Column="0"
                       Foreground="#888888"
                       FontSize="12"
                       VerticalAlignment="Center" />

            <Button x:Name="BtnSelect" Grid.Column="1"
                    Content="Select" Width="80" Height="28"
                    Click="BtnSelect_Click"
                    IsEnabled="False"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Margin="0,0,8,0"
                    Cursor="Hand" />
            <Button Grid.Column="2"
                    Content="Cancel" Width="80" Height="28"
                    Click="BtnCancel_Click"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0"
                    Cursor="Hand" />
        </Grid>
    </Grid>
</Window>
