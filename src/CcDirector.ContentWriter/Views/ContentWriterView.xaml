<UserControl x:Class="CcDirector.ContentWriter.Views.ContentWriterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <UserControl.Resources>
        <!-- Document list item style -->
        <Style x:Key="DocListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section card style -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Content list -->
            <ColumnDefinition Width="200" MinWidth="150" />
            <!-- Splitter -->
            <ColumnDefinition Width="Auto" />
            <!-- Terminal placeholder -->
            <ColumnDefinition Width="*" />
            <!-- Splitter -->
            <ColumnDefinition Width="Auto" />
            <!-- Content preview -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- COLUMN 0: Content List -->
        <DockPanel Grid.Column="0" Background="#252526">

            <!-- Header + New button -->
            <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4">
                <TextBlock Text="CONTENT"
                           Foreground="#888888"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button x:Name="BtnNewDocument"
                        Content="+ New"
                        Click="BtnNewDocument_Click"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Height="24" Padding="8,0"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Focusable="False" />
            </DockPanel>

            <!-- In Progress section -->
            <TextBlock DockPanel.Dock="Top"
                       Text="IN PROGRESS"
                       Foreground="#888888"
                       FontSize="10"
                       Margin="8,8,8,2" />
            <ListBox x:Name="InProgressList"
                     DockPanel.Dock="Top"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource DocListItemStyle}"
                     SelectionChanged="DocumentList_SelectionChanged"
                     MaxHeight="300">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#CCCCCC"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Modified, StringFormat='{}{0:MMM dd, HH:mm}'}"
                                       Foreground="#666666"
                                       FontSize="9" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Completed section -->
            <TextBlock DockPanel.Dock="Top"
                       Text="COMPLETED"
                       Foreground="#888888"
                       FontSize="10"
                       Margin="8,12,8,2" />
            <ListBox x:Name="CompletedList"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource DocListItemStyle}"
                     SelectionChanged="CompletedList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#AAAAAA"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Modified, StringFormat='{}{0:MMM dd, HH:mm}'}"
                                       Foreground="#666666"
                                       FontSize="9" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Splitter 1 -->
        <GridSplitter Grid.Column="1" Width="3"
                      Focusable="False"
                      Background="#1E1E1E"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" />

        <!-- COLUMN 2: Terminal Area (placeholder - will host embedded terminal) -->
        <DockPanel Grid.Column="2" Background="#1E1E1E">

            <!-- Terminal header bar -->
            <Border DockPanel.Dock="Top"
                    Background="#252526"
                    BorderBrush="#3C3C3C"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <DockPanel>
                    <TextBlock Text="CLAUDE CODE"
                               Foreground="#888888"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="SessionComboBox"
                              DockPanel.Dock="Right"
                              HorizontalAlignment="Right"
                              Width="180"
                              Background="#3C3C3C"
                              Foreground="#CCCCCC"
                              BorderBrush="#3C3C3C"
                              SelectionChanged="SessionComboBox_SelectionChanged"
                              ToolTip="Link a Claude Code session" />
                </DockPanel>
            </Border>

            <!-- Terminal host placeholder -->
            <Grid x:Name="TerminalHostPanel" Background="#1E1E1E">
                <TextBlock x:Name="TerminalPlaceholder"
                           Text="Select a session from the dropdown above to link a Claude Code terminal here."
                           Foreground="#555555"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="40" />
            </Grid>
        </DockPanel>

        <!-- Splitter 2 -->
        <GridSplitter Grid.Column="3" Width="3"
                      Focusable="False"
                      Background="#1E1E1E"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" />

        <!-- COLUMN 4: Content Preview -->
        <DockPanel Grid.Column="4" Background="#1E1E1E">

            <!-- Preview header -->
            <Border DockPanel.Dock="Top"
                    Background="#252526"
                    BorderBrush="#3C3C3C"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <DockPanel>
                    <TextBlock Text="PREVIEW"
                               Foreground="#888888"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="BtnAddSection"
                                Content="+ Section"
                                Click="BtnAddSection_Click"
                                Height="24" Padding="8,0"
                                Background="#3C3C3C"
                                Foreground="#CCCCCC"
                                BorderThickness="0"
                                Cursor="Hand"
                                Focusable="False"
                                Margin="0,0,4,0" />
                        <Button x:Name="BtnMarkComplete"
                                Content="Mark Complete"
                                Click="BtnMarkComplete_Click"
                                Height="24" Padding="8,0"
                                Background="#3C3C3C"
                                Foreground="#CCCCCC"
                                BorderThickness="0"
                                Cursor="Hand"
                                Focusable="False" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Status footer -->
            <Border DockPanel.Dock="Bottom"
                    Background="#252526"
                    BorderBrush="#3C3C3C"
                    BorderThickness="0,1,0,0"
                    Padding="8,4">
                <DockPanel>
                    <TextBlock x:Name="TxtFilePath"
                               Text=""
                               Foreground="#666666"
                               FontSize="10"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <TextBlock Text="Selected: "
                                   Foreground="#888888"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtSelectedSections"
                                   Text="None"
                                   Foreground="#007ACC"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  |  "
                                   Foreground="#3C3C3C"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtStatus"
                                   Text="No document loaded"
                                   Foreground="#888888"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Section cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SectionsPanel" Margin="12,12,12,0">

                    <!-- Document title -->
                    <TextBlock x:Name="TxtDocumentTitle"
                               Text=""
                               Foreground="#CCCCCC"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <Border Background="#007ACC" Height="2"
                            HorizontalAlignment="Left" Width="60"
                            Margin="0,0,0,16" />

                    <!-- Placeholder when no document -->
                    <TextBlock x:Name="PreviewPlaceholder"
                               Text="Select or create a document from the content list on the left."
                               Foreground="#555555"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Margin="0,40,0,0" />

                    <!-- Section cards rendered here -->
                    <ItemsControl x:Name="SectionsList"
                                  ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="SectionCard"
                                        Background="#252526"
                                        BorderThickness="2"
                                        CornerRadius="4"
                                        Margin="0,0,0,8"
                                        Padding="12,10"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="SectionCard_MouseLeftButtonDown">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#3C3C3C" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#007ACC" />
                                                    <Setter Property="Background" Value="#1A3A5C" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,6">
                                            <Border Background="#3C3C3C"
                                                    CornerRadius="3"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Id, StringFormat='[{0}]'}"
                                                           Foreground="#AAAAAA"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           FontFamily="Cascadia Mono, Consolas, Courier New" />
                                            </Border>
                                            <TextBlock Text="{Binding Heading}"
                                                       Foreground="#CCCCCC"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Body}"
                                                   Foreground="#AAAAAA"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="200" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Loading overlay -->
        <Border x:Name="LoadingOverlay"
                Grid.ColumnSpan="5"
                Background="#CC1E1E1E"
                Visibility="Collapsed">
            <TextBlock Text="Loading..."
                       Foreground="#888888"
                       FontSize="16"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
