<Window x:Class="CcDirector.ContentWriter.Views.NewDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Content Document"
        Width="400" SizeToContent="Height"
        Background="#252526"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Document Name"
                   Foreground="#CCCCCC"
                   FontSize="14"
                   Margin="0,0,0,8" />

        <TextBox x:Name="TxtName"
                 Grid.Row="1"
                 Background="#1E1E1E"
                 Foreground="#CCCCCC"
                 CaretBrush="#CCCCCC"
                 BorderBrush="#3C3C3C"
                 BorderThickness="1"
                 Padding="8,6"
                 FontSize="14" />

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Create" Width="80"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Height="28" Cursor="Hand"
                    IsDefault="True"
                    Click="BtnCreate_Click" />
            <Button Content="Cancel" Width="80"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Height="28" Cursor="Hand"
                    IsCancel="True" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
