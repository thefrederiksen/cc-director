[147C[H  Switch from "replace the collection" to "clear and refill the same collection" in [38;2;177;185;249mActionMapper.Map(UpdateActionDto, TblAction)[m:[K
[K
  action.TblActionEntities.Clear();[K
  [34mforeach [m([34mvar [mdto [34min [mactionDto.ActionEntities)[K
      action.TblActionEntities.Add(Map(dto));[K
[K
  action.TblActionSteps.Clear();[K
  [34mforeach [m([34mvar [mdto [34min [mactionDto.ActionSteps)[K
      action.TblActionSteps.Add(Map(dto));[K
