<Window x:Class="CcDirector.Wpf.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="480" Height="300"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#3C3C3C" BorderThickness="1">
        <Grid Margin="32,28,32,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Left">
                <TextBlock Text="CC"
                           FontFamily="Cascadia Mono, Consolas, Courier New"
                           FontSize="56"
                           FontWeight="Bold"
                           Foreground="#007ACC"
                           Margin="0,0,0,-6" />
                <TextBlock Text="DIRECTOR"
                           FontFamily="Cascadia Mono, Consolas, Courier New"
                           FontSize="15"
                           Foreground="#666666"
                           Padding="1,0,0,0" />
            </StackPanel>

            <!-- Accent line -->
            <Rectangle Grid.Row="1"
                       Height="2"
                       Fill="#007ACC"
                       HorizontalAlignment="Left"
                       Width="60"
                       Margin="0,12,0,0" />

            <!-- Version and date -->
            <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,8">
                <TextBlock x:Name="VersionText"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#888888" />
                <TextBlock x:Name="DateText"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#555555"
                           Margin="0,2,0,0" />
            </StackPanel>

            <!-- Footer: creator + loading -->
            <DockPanel Grid.Row="3">
                <TextBlock Text="Soren Frederiksen"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#555555"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Loading..."
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontStyle="Italic"
                           Foreground="#555555"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
