<Window x:Class="CcDirector.Wpf.NewSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Session"
        Width="900" Height="600"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tab Control -->
        <TabControl x:Name="MainTabs" Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3C3C3C"
                    SelectionChanged="MainTabs_SelectionChanged">

            <!-- New Session Tab (first) -->
            <TabItem Header="New Session" Background="#3C3C3C" Foreground="#CCCCCC">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Select a repository:"
                               Foreground="#CCCCCC" FontSize="14" Margin="0,0,0,8" />

                    <TextBox x:Name="RepoSearchBox" Grid.Row="1"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C" Padding="8"
                             TextChanged="RepoSearchBox_TextChanged"
                             ToolTip="Filter repositories by name or path" />

                    <ListBox x:Name="RepoList" Grid.Row="2"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C" Margin="0,8,0,0"
                             SelectionChanged="RepoList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" />
                                        <TextBlock Text="{Binding Path}" FontSize="10" Opacity="0.7" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="X"
                                            Click="BtnRemoveRepo_Click"
                                            Tag="{Binding Path}"
                                            Width="24" Height="24"
                                            Background="Transparent"
                                            Foreground="#CC4444"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontWeight="Bold"
                                            VerticalAlignment="Center"
                                            ToolTip="Remove from list" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PathInput" Grid.Column="0"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3C3C3C" Padding="8"
                                 VerticalContentAlignment="Center" />
                        <Button Grid.Column="1" Content="Browse..."
                                Click="BtnBrowse_Click"
                                Width="80" Margin="8,0,0,0"
                                Background="#3C3C3C" Foreground="#CCCCCC"
                                BorderThickness="0" Cursor="Hand" />
                    </Grid>

                    <CheckBox x:Name="BypassPermissionsCheckBox" Grid.Row="4"
                              Content="Bypass permission prompts"
                              IsChecked="True"
                              Foreground="#CCCCCC"
                              Margin="0,12,0,0"
                              ToolTip="When checked, Claude Code will not prompt for permission to execute tools" />

                    <CheckBox x:Name="RemoteControlCheckBox" Grid.Row="5"
                              Content="Enable Remote Control"
                              IsChecked="False"
                              Foreground="#CCCCCC"
                              Margin="0,8,0,0"
                              ToolTip="When checked, starts session in Remote Control mode for access from claude.ai or mobile app" />

                    <!-- Quick-launch coaching buttons -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,16,0,0">
                        <StackPanel.Resources>
                            <Style x:Key="CoachingButton" TargetType="Button">
                                <Setter Property="Background" Value="#2D2D30" />
                                <Setter Property="Foreground" Value="#CCCCCC" />
                                <Setter Property="BorderBrush" Value="#3C3C3C" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Padding" Value="16,8" />
                                <Setter Property="Margin" Value="0,0,8,0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#007ACC" />
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#007ACC" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>

                        <Button Content="Assistant" Tag="assistant"
                                Style="{StaticResource CoachingButton}"
                                Click="BtnCoaching_Click"
                                ToolTip="Life admin, contacts, routing" />
                        <Button Content="Health" Tag="health"
                                Style="{StaticResource CoachingButton}"
                                Click="BtnCoaching_Click"
                                ToolTip="Health, wellness, fitness" />
                        <Button Content="Business" Tag="business"
                                Style="{StaticResource CoachingButton}"
                                Click="BtnCoaching_Click"
                                ToolTip="Business strategy, consulting" />
                        <Button Content="Personal" Tag="personal"
                                Style="{StaticResource CoachingButton}"
                                Click="BtnCoaching_Click"
                                ToolTip="Relationships, emotional wellbeing" />
                        <Button Content="Growth" Tag="growth"
                                Style="{StaticResource CoachingButton}"
                                Click="BtnCoaching_Click"
                                ToolTip="Learning, mindset, skill development" />
                        <Button Content="Dev" Tag="dev"
                                Style="{StaticResource CoachingButton}"
                                Click="BtnCoaching_Click"
                                ToolTip="Software development coaching" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Resume Session Tab (second) -->
            <TabItem Header="Resume Session" Background="#3C3C3C" Foreground="#CCCCCC">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Resume a previous session:"
                               Foreground="#CCCCCC" FontSize="14" Margin="0,0,0,8" />

                    <TextBox x:Name="SessionSearchBox" Grid.Row="1"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C" Padding="8"
                             TextChanged="SessionSearchBox_TextChanged"
                             ToolTip="Filter sessions by project name or path" />

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <!-- Loading indicator -->
                        <TextBlock x:Name="LoadingText" Text="Loading sessions..."
                                   Foreground="#888888" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- No sessions message -->
                        <TextBlock x:Name="NoSessionsText" Text="No Claude Code sessions found"
                                   Foreground="#888888" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed" />

                        <!-- Session list -->
                        <ListBox x:Name="SessionList"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3C3C3C"
                                 Visibility="Collapsed"
                                 SelectionChanged="SessionList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Display name + repo suffix + color indicator -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                            <!-- Color indicator bar -->
                                            <Border Width="4" Height="16" CornerRadius="2" Margin="0,0,8,0"
                                                    Background="{Binding CustomColorBrush}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCustomColor}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                                            <!-- Repo name in parentheses when custom name is set -->
                                            <TextBlock Text="{Binding ProjectNameSuffix}" FontSize="11"
                                                       Foreground="#888888" Margin="6,0,0,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCustomName}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Message count and time -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding MessageCountDisplay}"
                                                       Foreground="#888888" FontSize="11" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding TimeAgo}"
                                                       Foreground="#888888" FontSize="11" />
                                        </StackPanel>

                                        <!-- Row 1: Summary -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding DisplaySummary}"
                                                   Foreground="#22C55E" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>
            <!-- Handovers Tab (third) -->
            <TabItem Header="Handovers" Background="#3C3C3C" Foreground="#CCCCCC">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Session handover documents:"
                               Foreground="#CCCCCC" FontSize="14" Margin="0,0,0,8" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: handover list -->
                        <Grid Grid.Column="0">
                            <!-- Loading indicator -->
                            <TextBlock x:Name="HandoverLoadingText" Text="Loading handovers..."
                                       Foreground="#888888" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <!-- No handovers message -->
                            <TextBlock x:Name="NoHandoversText"
                                       Text="No handovers found. Use /handover in a session to create one."
                                       Foreground="#888888" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextWrapping="Wrap" Margin="12"
                                       Visibility="Collapsed" />

                            <!-- Handover list -->
                            <ListBox x:Name="HandoverList"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     BorderBrush="#3C3C3C"
                                     Visibility="Collapsed"
                                     SelectionChanged="HandoverList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="13" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding RepoDisplay}" Foreground="#AAAAAA" FontSize="10" />
                                                <TextBlock Text="  " />
                                                <TextBlock Text="{Binding DateDisplay}" Foreground="#888888" FontSize="10" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- Right: preview -->
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Repo path header -->
                            <Border Grid.Row="0" Background="#2D2D30" Padding="12,8"
                                    BorderBrush="#3C3C3C" BorderThickness="1,1,1,0">
                                <StackPanel>
                                    <TextBlock x:Name="HandoverRepoPath"
                                               Foreground="#888888" FontSize="10"
                                               Text="No handover selected" />
                                </StackPanel>
                            </Border>

                            <!-- Preview content -->
                            <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3C3C3C"
                                    BorderThickness="1">
                                <Grid>
                                    <TextBlock x:Name="HandoverPlaceholder"
                                               Text="Select a handover to preview"
                                               Foreground="#555555" FontStyle="Italic"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBox x:Name="HandoverPreview"
                                                 Background="Transparent" Foreground="#CCCCCC"
                                                 BorderThickness="0" IsReadOnly="True"
                                                 TextWrapping="Wrap" Padding="12"
                                                 FontFamily="Cascadia Mono, Consolas, Courier New"
                                                 FontSize="12"
                                                 Visibility="Collapsed" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Copy to Clipboard (handovers tab only) -->
            <Button x:Name="BtnCopyHandover" Grid.Column="0"
                    Content="Copy to Clipboard" Width="130"
                    Click="BtnCopyHandover_Click"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Visibility="Collapsed"
                    ToolTip="Copy handover content to clipboard" />

            <!-- Right: Action + Cancel -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="BtnAction" Content="Resume Selected" Width="120"
                        Click="BtnAction_Click"
                        BorderThickness="0" Margin="0,0,8,0"
                        IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#22C55E" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#4A4A4A" />
                                    <Setter Property="Foreground" Value="#AAAAAA" />
                                    <Setter Property="Cursor" Value="Arrow" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Cancel" Width="80"
                        Click="BtnCancel_Click"
                        Background="#3C3C3C" Foreground="#CCCCCC"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
