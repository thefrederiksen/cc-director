<Window x:Class="CcDirector.Wpf.WorkflowConditionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Condition"
        Width="400" SizeToContent="Height"
        Background="#252526"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Check type -->
        <TextBlock Text="Condition Type" Foreground="#888888" FontSize="10"
                   FontWeight="SemiBold" Margin="0,0,0,4" />

        <ComboBox x:Name="CheckTypeCombo" Grid.Row="1"
                  Background="#1E1E1E" Foreground="#CCCCCC"
                  BorderBrush="#3C3C3C" BorderThickness="1"
                  Height="28" FontSize="11"
                  Margin="0,0,0,12"
                  SelectionChanged="CheckTypeCombo_SelectionChanged">
            <ComboBoxItem Content="Element Exists" Tag="elementExists" IsSelected="True" />
            <ComboBoxItem Content="URL Contains" Tag="urlContains" />
            <ComboBoxItem Content="Text Visible" Tag="textVisible" />
        </ComboBox>

        <!-- Selector / Value -->
        <TextBlock x:Name="InputLabel" Grid.Row="2" Text="CSS Selector"
                   Foreground="#888888" FontSize="10"
                   FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBox x:Name="InputBox" Grid.Row="3"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                 BorderThickness="1" Padding="8,6"
                 FontSize="11" Margin="0,0,0,16" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True" Click="BtnOk_Click" />
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
