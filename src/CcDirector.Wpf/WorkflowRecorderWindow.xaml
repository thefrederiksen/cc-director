<Window x:Class="CcDirector.Wpf.WorkflowRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workflow Recorder"
        Background="#252526"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <TextBlock x:Name="TitleText"
                   Foreground="#CCCCCC"
                   FontWeight="SemiBold" FontSize="14"
                   Margin="0,0,0,8" />

        <!-- Row 1: Status -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Status: " Foreground="#888888" FontSize="11" />
            <TextBlock x:Name="StatusText" Text="IDLE" Foreground="#CCCCCC"
                       FontSize="11" FontWeight="SemiBold" />
        </StackPanel>

        <!-- Row 2: Control buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnRecord" Content="Record" Click="BtnRecord_Click"
                    MinWidth="60" Height="26" FontSize="11"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand" />
            <Button x:Name="BtnStop" Content="Stop" Click="BtnStop_Click"
                    MinWidth="60" Height="26" FontSize="11"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0"
                    IsEnabled="False" />
            <Button x:Name="BtnClear" Content="Clear" Click="BtnClear_Click"
                    MinWidth="60" Height="26" FontSize="11"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
        </StackPanel>

        <!-- Row 3: Action log -->
        <Border Grid.Row="3" BorderBrush="#3C3C3C" BorderThickness="1"
                Background="#1E1E1E" Margin="0,0,0,8">
            <ScrollViewer x:Name="ActionLogScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="ActionLogText"
                           Foreground="#CCCCCC"
                           FontFamily="Cascadia Mono, Consolas, Courier New"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Padding="8,6" />
            </ScrollViewer>
        </Border>

        <!-- Row 4: Saved workflows header -->
        <TextBlock Grid.Row="4" Text="SAVED WORKFLOWS"
                   Foreground="#888888" FontSize="10" FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <!-- Row 5: Saved workflow list -->
        <ListBox x:Name="WorkflowList" Grid.Row="5"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 BorderBrush="#3C3C3C" BorderThickness="1"
                 Height="100" FontSize="11"
                 SelectionChanged="WorkflowList_SelectionChanged" />

        <!-- Row 6: Save controls -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBox x:Name="WorkflowNameBox"
                     Width="100" Height="26" FontSize="11"
                     Background="#1E1E1E" Foreground="#CCCCCC"
                     CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                     BorderThickness="1" Padding="6,3"
                     VerticalContentAlignment="Center" />
            <Button x:Name="BtnSave" Content="Save" Click="BtnSave_Click"
                    MinWidth="50" Height="26" FontSize="11"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
            <Button x:Name="BtnReplay" Content="Run" Click="BtnReplay_Click"
                    MinWidth="50" Height="26" FontSize="11"
                    Background="#22C55E" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0"
                    IsEnabled="False" />
            <Button x:Name="BtnParameterize" Content="Params" Click="BtnParameterize_Click"
                    MinWidth="50" Height="26" FontSize="11"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0"
                    IsEnabled="False" />
            <Button x:Name="BtnRuns" Content="Runs" Click="BtnRuns_Click"
                    MinWidth="50" Height="26" FontSize="11"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0"
                    IsEnabled="False" />
        </StackPanel>

        <!-- Row 7: Status bar -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock x:Name="ActionCountText" Text="Actions: 0"
                       Foreground="#666666" FontSize="10" />
            <TextBlock x:Name="ElapsedText" Text="  |  Elapsed: 0s"
                       Foreground="#666666" FontSize="10" />
        </StackPanel>
    </Grid>
</Window>
