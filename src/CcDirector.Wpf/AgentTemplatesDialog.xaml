<Window x:Class="CcDirector.Wpf.AgentTemplatesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Templates"
        Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="700" MinHeight="500"
        Background="#252526">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left panel: template list -->
        <DockPanel Grid.Column="0" Grid.Row="0">
            <!-- Toolbar -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnNew" Content="New" Click="BtnNew_Click"
                        Width="60" Height="26"
                        Background="#007ACC" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="11" />
                <Button x:Name="BtnDuplicate" Content="Duplicate" Click="BtnDuplicate_Click"
                        Width="70" Height="26" Margin="6,0,0,0"
                        Background="#3C3C3C" Foreground="#CCCCCC"
                        BorderThickness="0" Cursor="Hand" FontSize="11" />
                <Button x:Name="BtnDelete" Content="Delete" Click="BtnDelete_Click"
                        Width="60" Height="26" Margin="6,0,0,0"
                        Background="#5A1D1D" Foreground="#E88888"
                        BorderThickness="0" Cursor="Hand" FontSize="11" />
            </StackPanel>

            <!-- Template list -->
            <ListBox x:Name="TemplateList"
                     SelectionChanged="TemplateList_SelectionChanged"
                     Background="#1E1E1E" Foreground="#CCCCCC"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontSize="13">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,3">
                            <TextBlock Text="{Binding Name}" Foreground="#CCCCCC"
                                       FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}" Foreground="#888888"
                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                       MaxWidth="240" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Right panel: edit form -->
        <Border Grid.Column="2" Grid.Row="0"
                Background="#1E1E1E" CornerRadius="4"
                BorderBrush="#3C3C3C" BorderThickness="1"
                Padding="16,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="EditPanel" IsEnabled="False">
                    <!-- Name -->
                    <TextBlock Text="Name" Foreground="#888888" FontSize="11" Margin="0,0,0,3" />
                    <TextBox x:Name="TxtName" Height="28"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="13" />

                    <!-- Description -->
                    <TextBlock Text="Description" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <TextBox x:Name="TxtDescription" Height="28"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="13" />

                    <!-- Model -->
                    <TextBlock Text="Model" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <ComboBox x:Name="CmbModel" Height="28"
                              Background="#252526" Foreground="#CCCCCC"
                              BorderBrush="#3C3C3C" BorderThickness="1"
                              FontSize="13" IsEditable="True">
                        <ComboBoxItem Content="" />
                        <ComboBoxItem Content="haiku" />
                        <ComboBoxItem Content="sonnet" />
                        <ComboBoxItem Content="opus" />
                    </ComboBox>

                    <!-- MaxTurns + MaxBudgetUsd on same row -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Max Turns" Foreground="#888888" FontSize="11" Margin="0,0,0,3" />
                            <TextBox x:Name="TxtMaxTurns" Height="28"
                                     Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                                     BorderBrush="#3C3C3C" BorderThickness="1"
                                     Padding="6,4" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max Budget (USD)" Foreground="#888888" FontSize="11" Margin="0,0,0,3" />
                            <TextBox x:Name="TxtMaxBudget" Height="28"
                                     Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                                     BorderBrush="#3C3C3C" BorderThickness="1"
                                     Padding="6,4" FontSize="13" />
                        </StackPanel>
                    </Grid>

                    <!-- System Prompt -->
                    <TextBlock Text="System Prompt (replaces default)" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <TextBox x:Name="TxtSystemPrompt" Height="80"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="12" />

                    <!-- Append System Prompt -->
                    <TextBlock Text="Append System Prompt" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <TextBox x:Name="TxtAppendSystemPrompt" Height="80"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="12" />

                    <!-- Permission Mode + SkipPermissions on same row -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Permission Mode" Foreground="#888888" FontSize="11" Margin="0,0,0,3" />
                            <ComboBox x:Name="CmbPermissionMode" Height="28"
                                      Background="#252526" Foreground="#CCCCCC"
                                      BorderBrush="#3C3C3C" BorderThickness="1"
                                      FontSize="13">
                                <ComboBoxItem Content="" />
                                <ComboBoxItem Content="plan" />
                                <ComboBoxItem Content="acceptEdits" />
                                <ComboBoxItem Content="bypassPermissions" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,4">
                            <CheckBox x:Name="ChkSkipPermissions" Content="Skip Permissions"
                                      Foreground="#CCCCCC" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <!-- Tools -->
                    <TextBlock Text="Tools" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <TextBox x:Name="TxtTools" Height="28"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="13" />

                    <!-- Allowed Tools -->
                    <TextBlock Text="Allowed Tools (comma-separated)" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <TextBox x:Name="TxtAllowedTools" Height="28"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="13" />

                    <!-- Disallowed Tools -->
                    <TextBlock Text="Disallowed Tools (comma-separated)" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <TextBox x:Name="TxtDisallowedTools" Height="28"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="13" />

                    <!-- MCP Config Path -->
                    <TextBlock Text="MCP Config Path" Foreground="#888888" FontSize="11" Margin="0,10,0,3" />
                    <TextBox x:Name="TxtMcpConfigPath" Height="28"
                             Background="#252526" Foreground="#CCCCCC" CaretBrush="#CCCCCC"
                             BorderBrush="#3C3C3C" BorderThickness="1"
                             Padding="6,4" FontSize="13" />

                    <!-- Save button -->
                    <Button x:Name="BtnSave" Content="Save" Click="BtnSave_Click"
                            Width="80" Height="30" Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Background="#007ACC" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="12" FontWeight="SemiBold" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom bar -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                    Orientation="Horizontal" Margin="0,12,0,0"
                    HorizontalAlignment="Right">
            <Button x:Name="BtnLaunch" Content="Launch on Project..." Click="BtnLaunch_Click"
                    Height="30" Padding="12,0"
                    Background="#28A745" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="12" FontWeight="SemiBold" />
            <Button x:Name="BtnImport" Content="Import" Click="BtnImport_Click"
                    Width="70" Height="30" Margin="8,0,0,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" FontSize="12" />
            <Button x:Name="BtnExport" Content="Export" Click="BtnExport_Click"
                    Width="70" Height="30" Margin="8,0,0,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" FontSize="12" />
            <Button x:Name="BtnClose" Content="Close" Click="BtnClose_Click"
                    Width="70" Height="30" Margin="8,0,0,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" FontSize="12" />
        </StackPanel>
    </Grid>
</Window>
