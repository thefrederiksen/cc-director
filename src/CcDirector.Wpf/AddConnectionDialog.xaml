<Window x:Class="CcDirector.Wpf.AddConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Connection"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252526">

    <StackPanel Margin="16">
        <!-- Name -->
        <TextBlock Text="Connection Name"
                   Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4" />
        <TextBox x:Name="TxtName"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 BorderBrush="#3C3C3C" Padding="8"
                 TextChanged="TxtName_TextChanged"
                 ToolTip="Lowercase letters, numbers, and hyphens only" />
        <TextBlock x:Name="NameError" Text=""
                   Foreground="#F44747" FontSize="10"
                   Margin="0,2,0,0" Visibility="Collapsed" />

        <!-- Description -->
        <TextBlock Text="Description (optional)"
                   Foreground="#CCCCCC" FontSize="12" Margin="0,12,0,4" />
        <TextBox x:Name="TxtDescription"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 BorderBrush="#3C3C3C" Padding="8"
                 ToolTip="Brief description of this connection" />

        <!-- URL -->
        <TextBlock Text="URL (optional)"
                   Foreground="#CCCCCC" FontSize="12" Margin="0,12,0,4" />
        <TextBox x:Name="TxtUrl"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 BorderBrush="#3C3C3C" Padding="8"
                 ToolTip="Starting URL for this connection" />

        <!-- Tool Binding -->
        <TextBlock Text="Tool Binding (optional)"
                   Foreground="#CCCCCC" FontSize="12" Margin="0,12,0,4" />
        <ComboBox x:Name="CmbTool"
                  Background="#1E1E1E" Foreground="#CCCCCC"
                  BorderBrush="#3C3C3C" Padding="6"
                  SelectedIndex="0">
            <ComboBoxItem Content="(none)" />
            <ComboBoxItem Content="cc-linkedin" />
            <ComboBoxItem Content="cc-reddit" />
        </ComboBox>

        <!-- Buttons -->
        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnOk" Grid.Column="1"
                    Content="Add" Width="80"
                    Click="BtnOk_Click"
                    IsEnabled="False"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,8,0" />
            <Button Grid.Column="2"
                    Content="Cancel" Width="80"
                    Click="BtnCancel_Click"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand" />
        </Grid>
    </StackPanel>
</Window>
