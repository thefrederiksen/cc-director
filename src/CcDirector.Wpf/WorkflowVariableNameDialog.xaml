<Window x:Class="CcDirector.Wpf.WorkflowVariableNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Variable"
        Width="400" SizeToContent="Height"
        Background="#252526"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Foreground="#888888" FontSize="11" Margin="0,0,0,4">
            <Run Text="Current value: " />
            <Run x:Name="CurrentValueText" Foreground="#CCCCCC" />
        </TextBlock>

        <TextBlock Grid.Row="1" Text="Variable name (e.g. comment_text):"
                   Foreground="#CCCCCC" FontSize="12"
                   Margin="0,8,0,4" />

        <TextBox x:Name="VarNameBox" Grid.Row="2"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 CaretBrush="#CCCCCC" BorderBrush="#3C3C3C"
                 BorderThickness="1" Padding="8,6"
                 FontSize="12" FontFamily="Cascadia Mono, Consolas, Courier New" />

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True" Click="BtnOK_Click" />
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsCancel="True" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
