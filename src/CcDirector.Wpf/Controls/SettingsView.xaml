<UserControl x:Class="CcDirector.Wpf.Controls.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PanelBackground}">

    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
            <TextBlock Text="SETTINGS"
                       Foreground="{StaticResource TextForeground}"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center" />

            <!-- Right-aligned controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Alpha Mode toggle -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Alpha"
                               Foreground="#B45309"
                               FontWeight="SemiBold"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <CheckBox x:Name="AlphaModeToggle"
                              Click="AlphaModeToggle_Click"
                              Focusable="False"
                              VerticalAlignment="Center" />
                </StackPanel>

                <Button x:Name="BtnRefresh"
                        Content="Refresh"
                        Click="BtnRefresh_Click"
                        Focusable="False"
                        Height="28"
                        Padding="12,0"
                        Background="#3C3C3C"
                        Foreground="{StaticResource TextForeground}"
                        BorderThickness="0"
                        Cursor="Hand" />
            </StackPanel>
        </DockPanel>

        <!-- Loading text -->
        <TextBlock x:Name="LoadingText"
                   Text="Loading..."
                   Foreground="#888888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   DockPanel.Dock="Top"
                   Margin="0,40,0,0" />

        <!-- Settings content -->
        <ScrollViewer x:Name="ContentScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed"
                      Padding="16,0,16,16">
            <StackPanel x:Name="CategoriesPanel" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
