<UserControl x:Class="CcDirector.Wpf.Controls.SessionBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PanelBackground}">

    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
            <TextBlock Text="SESSIONS"
                       Foreground="{StaticResource TextForeground}"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center" />

            <!-- Right-aligned controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnRefresh"
                        Content="Refresh"
                        Click="BtnRefresh_Click"
                        Focusable="False"
                        Height="28"
                        Padding="12,0"
                        Background="#3C3C3C"
                        Foreground="{StaticResource TextForeground}"
                        BorderThickness="0"
                        Cursor="Hand" />
            </StackPanel>
        </DockPanel>

        <!-- Search box -->
        <Border DockPanel.Dock="Top"
                Margin="16,0,16,8"
                Background="#3C3C3C"
                CornerRadius="4"
                Padding="8,4">
            <TextBox x:Name="SearchBox"
                     Background="Transparent"
                     Foreground="#CCCCCC"
                     BorderThickness="0"
                     FontSize="13"
                     CaretBrush="#CCCCCC"
                     TextChanged="SearchBox_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Tag" Value="Search sessions..." />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Border>

        <!-- Loading text -->
        <TextBlock x:Name="LoadingText"
                   Text="Loading..."
                   Foreground="#888888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   DockPanel.Dock="Top"
                   Margin="0,40,0,0" />

        <!-- Session tree -->
        <ScrollViewer x:Name="ContentScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed"
                      Padding="16,0,16,16">
            <StackPanel x:Name="ProjectsPanel" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
