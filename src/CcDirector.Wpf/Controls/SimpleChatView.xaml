<UserControl x:Class="CcDirector.Wpf.Controls.SimpleChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CcDirector.Wpf.Controls"
             Background="#1E1E1E">
    <UserControl.Resources>
        <!-- Plain text template: user messages, status, permission notices -->
        <DataTemplate x:Key="PlainChatTemplate" DataType="{x:Type local:ChatMessageViewModel}">
            <Grid Margin="{Binding BubbleMargin}">
                <StackPanel HorizontalAlignment="{Binding Alignment}">
                    <Border Background="{Binding BubbleBackground}"
                            CornerRadius="{Binding BubbleCornerRadius}"
                            Padding="{Binding BubblePadding}"
                            MaxWidth="600">
                        <TextBlock Text="{Binding Text}"
                                   Foreground="{Binding TextForegroundBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="{Binding FontSize}"
                                   FontStyle="{Binding FontStyleValue}"
                                   TextWrapping="Wrap" />
                    </Border>
                    <TextBlock Text="{Binding Timestamp}"
                               Foreground="#888888"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Margin="4,2,4,0"
                               HorizontalAlignment="{Binding Alignment}"
                               Visibility="{Binding TimestampVisibility}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Rich content template: assistant messages with markdown rendering -->
        <DataTemplate x:Key="RichChatTemplate" DataType="{x:Type local:ChatMessageViewModel}">
            <Grid Margin="{Binding BubbleMargin}">
                <StackPanel HorizontalAlignment="{Binding Alignment}">
                    <Border Background="{Binding BubbleBackground}"
                            CornerRadius="{Binding BubbleCornerRadius}"
                            Padding="{Binding BubblePadding}"
                            MaxWidth="720">
                        <FlowDocumentScrollViewer Document="{Binding RenderedDocument}"
                                                  IsToolBarVisible="False"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Background="Transparent"
                                                  Foreground="#CCCCCC"
                                                  Focusable="False" />
                    </Border>
                    <TextBlock Text="{Binding Timestamp}"
                               Foreground="#888888"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Margin="4,2,4,0"
                               HorizontalAlignment="{Binding Alignment}"
                               Visibility="{Binding TimestampVisibility}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <local:ChatMessageTemplateSelector x:Key="ChatTemplateSelector"
                                           PlainTemplate="{StaticResource PlainChatTemplate}"
                                           RichTemplate="{StaticResource RichChatTemplate}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Chat messages area -->
            <RowDefinition Height="*" />
            <!-- Progress bar area -->
            <RowDefinition Height="Auto" />
            <!-- Input area -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Chat messages -->
        <ScrollViewer x:Name="ChatScroller" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8">
            <ItemsControl x:Name="ChatItems"
                          ItemTemplateSelector="{StaticResource ChatTemplateSelector}" />
        </ScrollViewer>

        <!-- Empty state placeholder -->
        <TextBlock x:Name="EmptyText" Grid.Row="0"
                   Text="Type a message to start chatting with Claude."
                   Foreground="#888888"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <!-- Progress bar area -->
        <Border x:Name="ProgressArea" Grid.Row="1"
                Visibility="Collapsed"
                Padding="12,6">
            <StackPanel>
                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             Background="#3C3C3C"
                             Foreground="#007ACC"
                             BorderThickness="0" />
                <TextBlock x:Name="ProgressText"
                           Text="Claude is working..."
                           Foreground="#888888"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontStyle="Italic"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Input area -->
        <Border Grid.Row="2"
                Background="#1E1E1E"
                BorderBrush="#3C3C3C"
                BorderThickness="0,1,0,0"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ChatInput" Grid.Column="0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinLines="2"
                         MaxLines="6"
                         Background="#1E1E1E"
                         Foreground="#CCCCCC"
                         CaretBrush="#CCCCCC"
                         FontFamily="Cascadia Mono, Consolas, Courier New"
                         FontSize="13"
                         BorderBrush="#3C3C3C"
                         BorderThickness="1"
                         Padding="8,6"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="ChatInput_KeyDown" />
                <Button x:Name="SendButton" Grid.Column="1"
                        Content="Send"
                        Background="#007ACC"
                        Foreground="#FFFFFF"
                        FontFamily="Segoe UI"
                        FontSize="13"
                        Padding="16,8"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SendButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A8AD4" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
