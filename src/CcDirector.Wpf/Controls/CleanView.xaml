<UserControl x:Class="CcDirector.Wpf.Controls.CleanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CcDirector.Wpf.Controls"
             Background="#1E1E1E">
    <UserControl.Resources>

        <!-- ===== Shared card wrapper style ===== -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{Binding CardBackground}" />
            <Setter Property="BorderBrush" Value="{Binding CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="8,4" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <!-- Icon badge -->
        <Style x:Key="IconBadge" TargetType="Border">
            <Setter Property="Background" Value="{Binding IconBackground}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <!-- Header text -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Subheader text -->
        <Style x:Key="SubheaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!-- Code/content text -->
        <Style x:Key="ContentText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MaxHeight" Value="300" />
        </Style>

        <!-- Result/output area -->
        <Style x:Key="ResultBorder" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <!-- Pending indicator -->
        <Style x:Key="PendingText" TargetType="TextBlock">
            <Setter Property="Text" Value="Running..." />
            <Setter Property="Foreground" Value="#D97706" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <!-- ===== TEXT WIDGET - Assistant text messages ===== -->
        <DataTemplate x:Key="TextWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource IconBadge}">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}" />
                    </StackPanel>
                    <!-- Content -->
                    <TextBlock Text="{Binding Content}"
                               Foreground="#CCCCCC"
                               FontFamily="Segoe UI" FontSize="13"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               LineHeight="20" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== THINKING WIDGET - Collapsible thinking block ===== -->
        <DataTemplate x:Key="ThinkingWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}" Opacity="0.6">
                <Expander IsExpanded="False" Foreground="#888888">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource IconBadge}">
                                <TextBlock Text="{Binding IconText}" Foreground="White"
                                           FontFamily="Cascadia Mono" FontSize="9"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}"
                                       Foreground="#888888" />
                        </StackPanel>
                    </Expander.Header>
                    <TextBlock Text="{Binding Content}"
                               Foreground="#666666"
                               FontFamily="Segoe UI" FontSize="11"
                               TextWrapping="Wrap" Margin="34,4,0,0"
                               FontStyle="Italic" />
                </Expander>
            </Border>
        </DataTemplate>

        <!-- ===== BASH WIDGET - Terminal commands ===== -->
        <DataTemplate x:Key="BashWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource IconBadge}">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}" />
                        <TextBlock Text="{Binding Subheader}" Style="{StaticResource SubheaderText}"
                                   Visibility="{Binding SubheaderVisibility}" />
                    </StackPanel>
                    <!-- Command -->
                    <Border Background="#0C0C0C" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                        <TextBlock Text="{Binding Content}"
                                   Foreground="#22C55E"
                                   Style="{StaticResource ContentText}" />
                    </Border>
                    <!-- Result -->
                    <Border Style="{StaticResource ResultBorder}"
                            Visibility="{Binding ResultVisibility}">
                        <TextBlock Text="{Binding Result}"
                                   Foreground="{Binding ResultForeground}"
                                   Style="{StaticResource ContentText}"
                                   FontSize="11" />
                    </Border>
                    <!-- Pending -->
                    <TextBlock Style="{StaticResource PendingText}"
                               Visibility="{Binding PendingVisibility}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== FILE WIDGET - Read/Write/Edit operations ===== -->
        <DataTemplate x:Key="FileWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource IconBadge}">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}" />
                        <TextBlock Text="{Binding Subheader}" Style="{StaticResource SubheaderText}"
                                   Visibility="{Binding SubheaderVisibility}" />
                    </StackPanel>
                    <!-- Content (for Write/Edit shows content preview) -->
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="8,6" Margin="0,8,0,0"
                            Visibility="{Binding ContentVisibility}">
                        <TextBlock Text="{Binding Content}"
                                   Foreground="#D4D4D4"
                                   Style="{StaticResource ContentText}"
                                   FontSize="11" />
                    </Border>
                    <!-- Result -->
                    <Border Style="{StaticResource ResultBorder}"
                            Visibility="{Binding ResultVisibility}">
                        <TextBlock Text="{Binding Result}"
                                   Foreground="{Binding ResultForeground}"
                                   Style="{StaticResource ContentText}"
                                   FontSize="11" />
                    </Border>
                    <!-- Pending -->
                    <TextBlock Style="{StaticResource PendingText}"
                               Visibility="{Binding PendingVisibility}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== SEARCH WIDGET - Grep/Glob results ===== -->
        <DataTemplate x:Key="SearchWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource IconBadge}">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}" />
                        <TextBlock Text="{Binding Subheader}" Style="{StaticResource SubheaderText}"
                                   Visibility="{Binding SubheaderVisibility}" />
                    </StackPanel>
                    <!-- Path -->
                    <TextBlock Text="{Binding Content}"
                               Foreground="#888888"
                               FontFamily="Segoe UI" FontSize="11"
                               Margin="34,4,0,0"
                               Visibility="{Binding ContentVisibility}" />
                    <!-- Result -->
                    <Border Style="{StaticResource ResultBorder}"
                            Visibility="{Binding ResultVisibility}">
                        <TextBlock Text="{Binding Result}"
                                   Foreground="{Binding ResultForeground}"
                                   Style="{StaticResource ContentText}"
                                   FontSize="11" />
                    </Border>
                    <!-- Pending -->
                    <TextBlock Style="{StaticResource PendingText}"
                               Visibility="{Binding PendingVisibility}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== TODO WIDGET - Task list with checkboxes ===== -->
        <DataTemplate x:Key="TodoWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource IconBadge}">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}" />
                    </StackPanel>
                    <!-- Todo items -->
                    <TextBlock Text="{Binding Content}"
                               Foreground="#CCCCCC"
                               Style="{StaticResource ContentText}"
                               FontSize="12"
                               Margin="34,6,0,0" />
                    <!-- Pending -->
                    <TextBlock Style="{StaticResource PendingText}"
                               Visibility="{Binding PendingVisibility}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== USER MESSAGE WIDGET ===== -->
        <DataTemplate x:Key="UserWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Grid Margin="60,4,8,4" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Rewind button (opens context menu for confirmation) -->
                <Button Grid.Column="0"
                        Click="RewindButton_Click"
                        Tag="{Binding SnapshotEntryNumber}"
                        Visibility="{Binding RewindVisibility}"
                        ToolTip="Rewind to before this prompt"
                        Width="20" Height="20"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        Cursor="Hand">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Reset to here"
                                      Tag="{Binding SnapshotEntryNumber}"
                                      Click="RewindMenuItem_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Opacity" Value="0.4" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1.0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="X" Foreground="#EF4444"
                               FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <!-- Message bubble -->
                <Border Grid.Column="1" Padding="12,10"
                        Background="#094771" CornerRadius="6">
                    <TextBlock Text="{Binding Content}"
                               Foreground="White"
                               FontFamily="Segoe UI" FontSize="13"
                               TextWrapping="Wrap"
                               MaxWidth="600" />
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ===== SKILL WIDGET - Slash command invocations ===== -->
        <DataTemplate x:Key="SkillWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource IconBadge}">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}" />
                        <TextBlock Text="{Binding Subheader}" Style="{StaticResource SubheaderText}"
                                   Visibility="{Binding SubheaderVisibility}" />
                    </StackPanel>
                    <!-- Result -->
                    <Border Style="{StaticResource ResultBorder}"
                            Visibility="{Binding ResultVisibility}">
                        <TextBlock Text="{Binding Result}"
                                   Foreground="{Binding ResultForeground}"
                                   Style="{StaticResource ContentText}"
                                   FontSize="11" />
                    </Border>
                    <!-- Pending -->
                    <TextBlock Style="{StaticResource PendingText}"
                               Visibility="{Binding PendingVisibility}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== GENERIC TOOL WIDGET - Agent and unknown tools ===== -->
        <DataTemplate x:Key="GenericToolWidgetTemplate" DataType="{x:Type local:CleanWidgetViewModel}">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource IconBadge}">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource HeaderText}" />
                        <TextBlock Text="{Binding Subheader}" Style="{StaticResource SubheaderText}"
                                   Visibility="{Binding SubheaderVisibility}" />
                    </StackPanel>
                    <!-- Content -->
                    <TextBlock Text="{Binding Content}"
                               Foreground="#AAAAAA"
                               Style="{StaticResource ContentText}"
                               FontSize="11"
                               Margin="34,6,0,0"
                               Visibility="{Binding ContentVisibility}" />
                    <!-- Result -->
                    <Border Style="{StaticResource ResultBorder}"
                            Visibility="{Binding ResultVisibility}">
                        <TextBlock Text="{Binding Result}"
                                   Foreground="{Binding ResultForeground}"
                                   Style="{StaticResource ContentText}"
                                   FontSize="11" />
                    </Border>
                    <!-- Pending -->
                    <TextBlock Style="{StaticResource PendingText}"
                               Visibility="{Binding PendingVisibility}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Template Selector -->
        <local:WidgetTemplateSelector x:Key="WidgetSelector"
                                      TextTemplate="{StaticResource TextWidgetTemplate}"
                                      ThinkingTemplate="{StaticResource ThinkingWidgetTemplate}"
                                      BashTemplate="{StaticResource BashWidgetTemplate}"
                                      FileTemplate="{StaticResource FileWidgetTemplate}"
                                      SearchTemplate="{StaticResource SearchWidgetTemplate}"
                                      TodoTemplate="{StaticResource TodoWidgetTemplate}"
                                      UserTemplate="{StaticResource UserWidgetTemplate}"
                                      SkillTemplate="{StaticResource SkillWidgetTemplate}"
                                      GenericToolTemplate="{StaticResource GenericToolWidgetTemplate}" />

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Widget cards area -->
            <RowDefinition Height="*" />
            <!-- Progress bar area -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Widget cards -->
        <ScrollViewer x:Name="WidgetScroller" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="4">
            <ItemsControl x:Name="WidgetItems"
                          ItemTemplateSelector="{StaticResource WidgetSelector}" />
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyText" Grid.Row="0"
                   Text="Start a Claude Code session to see rich output here."
                   Foreground="#888888"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <!-- Loading state -->
        <TextBlock x:Name="LoadingText" Grid.Row="0"
                   Text="Loading session output..."
                   Foreground="#888888"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed" />

        <!-- Status bar area -->
        <Border x:Name="StatusArea" Grid.Row="1" Padding="12,6">
            <Grid>
                <!-- Working state: progress bar + text -->
                <StackPanel x:Name="ProgressArea" Visibility="Collapsed">
                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 Background="#3C3C3C"
                                 Foreground="#007ACC"
                                 BorderThickness="0" />
                    <TextBlock x:Name="ProgressText"
                               Text="Claude is working..."
                               Foreground="#888888"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontStyle="Italic"
                               Margin="0,4,0,0" />
                </StackPanel>
                <!-- Your Turn state -->
                <TextBlock x:Name="YourTurnText"
                           Text="Your Turn"
                           Foreground="#22C55E"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Visibility="Collapsed"
                           HorizontalAlignment="Left" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
