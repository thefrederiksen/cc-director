<Window x:Class="CcDirector.Wpf.ResumeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resume Session"
        Width="650" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select a session to resume:"
                   Foreground="#CCCCCC"
                   FontSize="14"
                   Margin="0,0,0,10" />

        <!-- Loading text (shown until data arrives) -->
        <TextBlock x:Name="LoadingText"
                   Grid.Row="1"
                   Text="Loading..."
                   Foreground="#888888"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <!-- Session list -->
        <ListBox x:Name="SessionList"
                 Grid.Row="1"
                 Background="#1E1E1E"
                 BorderBrush="#3C3C3C"
                 BorderThickness="1"
                 Foreground="#CCCCCC"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="SessionList_MouseDoubleClick"
                 Visibility="Collapsed">
            <ListBox.Resources>
                <!-- Selected item colors -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#094771" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#094771" />
            </ListBox.Resources>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,6,4,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Filename (bold) -->
                        <TextBlock Grid.Row="0"
                                   Text="{Binding FileName}"
                                   Foreground="#CCCCCC"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />

                        <!-- Date and size -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding LastModified}"
                                       Foreground="#888888"
                                       FontSize="11" />
                            <TextBlock Text="  --  "
                                       Foreground="#555555"
                                       FontSize="11" />
                            <TextBlock Text="{Binding FileSize}"
                                       Foreground="#888888"
                                       FontSize="11" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BtnOk"
                    Content="OK"
                    Width="90" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="BtnOk_Click" />
            <Button x:Name="BtnCancel"
                    Content="Cancel"
                    Width="90" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsCancel="True"
                    Margin="8,0,0,0"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
