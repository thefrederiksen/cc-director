<Window x:Class="TerminalTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Terminal Test" Width="1024" Height="768"
        Background="#0C0C0C" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#1E1E1E" Height="32">
            <Button x:Name="BtnLive" Content="Live" Width="50" Margin="4,2" Click="BtnMode_Click" Tag="Live" FontWeight="Bold"/>
            <Button x:Name="BtnTest" Content="Test" Width="50" Margin="4,2" Click="BtnMode_Click" Tag="Test"/>
            <Separator Width="10"/>
            <Button x:Name="BtnOrg" Content="ORG" Width="50" Margin="4,2" Click="BtnRenderer_Click" Tag="ORG"/>
            <Button x:Name="BtnPro" Content="PRO" Width="50" Margin="4,2" Click="BtnRenderer_Click" Tag="PRO"/>
            <Button x:Name="BtnLite" Content="LITE" Width="50" Margin="4,2" Click="BtnRenderer_Click" Tag="LITE"/>
            <Button x:Name="BtnCard" Content="CARD" Width="50" Margin="4,2" Click="BtnRenderer_Click" Tag="CARD"/>
            <Separator Width="10"/>
            <Button x:Name="BtnCapture" Content="Capture" Width="70" Margin="4,2" Click="BtnCapture_Click"/>
            <TextBlock x:Name="TxtStatus" Foreground="#888" VerticalAlignment="Center" Margin="10,0" Text="Starting..."/>
        </StackPanel>

        <Border x:Name="TerminalArea" Background="#0C0C0C">
        </Border>
    </DockPanel>
</Window>
