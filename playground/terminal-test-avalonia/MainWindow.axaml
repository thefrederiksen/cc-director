<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TerminalTestAvalonia.MainWindow"
        Title="Terminal Test"
        Width="1100" Height="600"
        Background="#0C0C0C">

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#111" Padding="8">
            <TextBlock x:Name="StatusText" Text="Starting..." Foreground="#AAA"
                       FontFamily="Cascadia Mono, Consolas" FontSize="11" />
        </Border>

        <Grid x:Name="TerminalHost" />
    </DockPanel>
</Window>
